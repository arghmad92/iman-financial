---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Full Financial Planning — Iman Abdul Rahim">
  <!-- Hero Section -->
  <section class="section hero">
    <div class="container">
      <div class="hero__badge">Comprehensive Service</div>
      <h1 class="hero__title">Full Financial Planning</h1>
      <p class="hero__subtitle">
        Engagement setahun yang direka untuk transform setiap aspek kewangan you.
        Kita akan bina plan yang menyeluruh — align duit you dengan values, goals, dan impian you.
      </p>
      <div class="hero__actions">
        <a href="https://wa.me/60186617981" class="btn btn--primary" target="_blank" rel="noopener noreferrer">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Jom Book Discovery Call
        </a>
        <a href="#pillars" class="btn btn--outline">Tengok 6 Pillars</a>
      </div>
    </div>
  </section>

  <!-- 6 Planning Pillars -->
  <section class="section pillars" id="pillars">
    <div class="container">
      <div class="section__header">
        <h2 class="section__title">6 Tiang Utama Financial Plan You</h2>
        <p class="section__subtitle">Setiap financial plan yang mantap dibina atas foundation yang kukuh. Ni 6 pillars yang kita akan go through sama-sama.</p>
      </div>
      <div class="pillars__grid">
        <div class="card pillar-card">
          <div class="pillar-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <h3 class="pillar-card__title">Cash Flow Planning</h3>
          <p class="pillar-card__desc">Bina foundation kewangan yang kukuh dengan manage income, expenses, savings, dan hutang dengan betul.</p>
        </div>
        <div class="card pillar-card">
          <div class="pillar-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <h3 class="pillar-card__title">Investment Planning</h3>
          <p class="pillar-card__desc">Grow kekayaan you secara strategic dengan portfolio yang tailored ikut risk profile dan long-term goals you.</p>
        </div>
        <div class="card pillar-card">
          <div class="pillar-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 class="pillar-card__title">Risk Management</h3>
          <p class="pillar-card__desc">Protect apa yang paling penting dalam hidup you dengan insurance dan takaful coverage yang smart.</p>
        </div>
        <div class="card pillar-card">
          <div class="pillar-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <h3 class="pillar-card__title">Estate Planning</h3>
          <p class="pillar-card__desc">Pastikan legacy you selamat dan orang tersayang terjaga — termasuk preparation wasiat.</p>
        </div>
        <div class="card pillar-card">
          <div class="pillar-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3 class="pillar-card__title">Goals-Based Planning</h3>
          <p class="pillar-card__desc">Rumah impian, pendidikan anak, pencen awal — plan setiap milestone dalam hidup you dengan intention.</p>
        </div>
        <div class="card pillar-card">
          <div class="pillar-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
          </div>
          <h3 class="pillar-card__title">Tax Planning</h3>
          <p class="pillar-card__desc">Maximize kekayaan you dengan strategi tax yang smart dan compliant — simpan lebih, bayar yang patut je.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Detailed Pillar Sections -->
  <section class="section details">
    <div class="container">
      <div class="section__header">
        <h2 class="section__title">Jom Tengok Setiap Pillar Dengan Lebih Dekat</h2>
        <p class="section__subtitle">Tengok macam mana setiap area planning ni work together untuk bagi you gambaran kewangan yang lengkap.</p>
      </div>

      <div class="detail-block">
        <div class="detail-block__number">01</div>
        <div class="detail-block__content">
          <h3 class="detail-block__title">Cash Flow Management</h3>
          <p class="detail-block__text">
            Cash flow ni macam nadi financial plan you. Kita akan map out setiap ringgit yang masuk dan keluar,
            identify area yang boleh improve, dan create sistem yang sustainable — supaya you boleh save consistently,
            bayar hutang secara strategic, dan bina emergency fund yang bagi you ketenangan. Dari sinilah
            clarity kewangan bermula.
          </p>
        </div>
      </div>

      <div class="detail-block detail-block--alt">
        <div class="detail-block__number">02</div>
        <div class="detail-block__content">
          <h3 class="detail-block__title">Investment Planning</h3>
          <p class="detail-block__text">
            Nak grow kekayaan bukan sekadar pilih product yang betul je — you perlukan strategy.
            Kita akan assess risk tolerance, time horizon, dan financial goals you untuk bina diversified portfolio
            yang sesuai untuk you. Dari unit trusts dan ETFs sampai EPF optimization dan Shariah-compliant options,
            investment plan you akan se-unique impian you sendiri.
          </p>
        </div>
      </div>

      <div class="detail-block">
        <div class="detail-block__number">03</div>
        <div class="detail-block__content">
          <h3 class="detail-block__title">Wealth Protection</h3>
          <p class="detail-block__text">
            Hidup ni tak boleh predict kan. Risk management melalui insurance dan takaful pastikan kalau ada apa-apa berlaku,
            financial progress you tak terjejas. Kita akan review coverage you sekarang, identify gaps, dan recommend
            solutions yang protect income, kesihatan, dan keluarga you — tanpa over-insure atau bazir premium.
          </p>
        </div>
      </div>

      <div class="detail-block detail-block--alt">
        <div class="detail-block__number">04</div>
        <div class="detail-block__content">
          <h3 class="detail-block__title">Estate Planning</h3>
          <p class="detail-block__text">
            Estate planning bukan untuk orang kaya je tau — ini untuk sesiapa yang nak pastikan aset diagihkan
            ikut kehendak sendiri. Kita akan tolong you set up wasiat (Islamic will), faham implikasi faraid,
            dan bina plan yang protect orang tersayang dan jaga legacy you
            untuk generasi akan datang.
          </p>
        </div>
      </div>

      <div class="detail-block">
        <div class="detail-block__number">05</div>
        <div class="detail-block__content">
          <h3 class="detail-block__title">Retirement Planning</h3>
          <p class="detail-block__text">
            Bila you nak retire? Macam mana retirement impian you nampak? Kita akan kira the numbers,
            bina savings trajectory, dan create investment strategy untuk sampai ke situ. Sama ada you impikan
            early retirement umur 45 atau hidup selesa lepas 60, kita akan map out the path dan track
            progress you setiap langkah.
          </p>
        </div>
      </div>

      <div class="detail-block detail-block--alt">
        <div class="detail-block__number">06</div>
        <div class="detail-block__content">
          <h3 class="detail-block__title">Tax Planning</h3>
          <p class="detail-block__text">
            Setiap ringgit yang you jimat dari tax boleh dihalakan ke goals you. Kita akan review situasi tax you,
            identify reliefs dan deductions yang eligible, dan implement strategies untuk minimize tax burden you
            secara legal dan ethical. Dari PRS contributions sampai education deductions, kita pastikan you
            simpan lebih dari apa yang you earn.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Engagement Timeline -->
  <section class="section timeline-section">
    <div class="container">
      <div class="section__header">
        <h2 class="section__title">Timeline Engagement You</h2>
        <p class="section__subtitle">Macam ni lah journey financial planning you selama setahun — dari mula sampai habis.</p>
      </div>
      <div class="timeline">
        <div class="timeline__item">
          <div class="timeline__marker">1</div>
          <div class="timeline__content">
            <h4 class="timeline__title">Discovery &amp; Goal-Setting Session</h4>
            <p class="timeline__desc">Kita mula dengan borak mendalam pasal hidup you, values, dan apa yang you nak capai dari segi kewangan. Ni masa kita kenal antara satu sama lain.</p>
          </div>
        </div>
        <div class="timeline__item">
          <div class="timeline__marker">2</div>
          <div class="timeline__content">
            <h4 class="timeline__title">Kumpul Data &amp; Analisis</h4>
            <p class="timeline__desc">You share dokumen kewangan — income, expenses, assets, liabilities, insurance policies — dan kita akan analyse semuanya dengan teliti.</p>
          </div>
        </div>
        <div class="timeline__item">
          <div class="timeline__marker">3</div>
          <div class="timeline__content">
            <h4 class="timeline__title">Presentation Financial Plan You</h4>
            <p class="timeline__desc">Kita present financial plan yang detailed dan personalised, cover semua 6 pillars, lengkap dengan recommendations yang you boleh terus buat.</p>
          </div>
        </div>
        <div class="timeline__item">
          <div class="timeline__marker">4</div>
          <div class="timeline__content">
            <h4 class="timeline__title">Implementation Support</h4>
            <p class="timeline__desc">I takkan bagi plan lepas tu tinggalkan you. Kita akan guide you through setiap step implementation — dari buka akaun sampai adjust coverage.</p>
          </div>
        </div>
        <div class="timeline__item">
          <div class="timeline__marker">5</div>
          <div class="timeline__content">
            <h4 class="timeline__title">Review &amp; Update Berkala</h4>
            <p class="timeline__desc">Hidup berubah, plan you pun kena ikut. Kita akan regularly review dan adjust plan you bila keadaan you berubah.</p>
          </div>
        </div>
        <div class="timeline__item">
          <div class="timeline__marker">6</div>
          <div class="timeline__content">
            <h4 class="timeline__title">Check-In Setiap 6 Bulan</h4>
            <p class="timeline__desc">Dua kali setahun, kita duduk untuk comprehensive review — pastikan you on track dan celebrate progress you sama-sama.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section cta-section">
    <div class="container">
      <div class="cta-block">
        <h2 class="cta-block__title">Financial planning yang se-dynamic hidup you</h2>
        <p class="cta-block__text">
          Dah ready nak take control of kewangan you? Jom kita mula dengan borak dulu.
        </p>
        <a href="https://wa.me/60186617981" class="btn btn--primary btn--lg" target="_blank" rel="noopener noreferrer">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Chat on WhatsApp
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero Section */
  .hero {
    text-align: center;
    padding: 6rem 1.5rem 4rem;
    background: linear-gradient(135deg, var(--cream) 0%, var(--blush) 50%, var(--pink-soft) 100%);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--rose-gold) 0%, transparent 70%);
    opacity: 0.08;
    pointer-events: none;
  }

  .hero__badge {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    background: rgba(183, 110, 121, 0.1);
    border: 1px solid var(--rose-gold);
    border-radius: 50px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--rose-gold);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .hero__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    color: var(--text);
    margin-bottom: 1.25rem;
    line-height: 1.15;
  }

  .hero__subtitle {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.15rem;
    color: var(--text-secondary);
    max-width: 640px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    border-radius: 50px;
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
    border: none;
  }

  .btn--primary {
    background: var(--rose-gold);
    color: var(--white);
    box-shadow: 0 4px 20px rgba(183, 110, 121, 0.3);
  }

  .btn--primary:hover {
    background: var(--pink);
    transform: translateY(-2px);
    box-shadow: 0 6px 25px rgba(183, 110, 121, 0.4);
  }

  .btn--outline {
    background: transparent;
    color: var(--rose-gold);
    border: 2px solid var(--rose-gold);
  }

  .btn--outline:hover {
    background: var(--rose-gold);
    color: var(--white);
    transform: translateY(-2px);
  }

  .btn--lg {
    padding: 1rem 2.5rem;
    font-size: 1.1rem;
  }

  /* Section Styles */
  .section {
    padding: 5rem 1.5rem;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section__header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .section__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    color: var(--text);
    margin-bottom: 1rem;
  }

  .section__subtitle {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.05rem;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Pillars Grid */
  .pillars {
    background: var(--white);
  }

  .pillars__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .pillar-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
    transition: all 0.3s ease;
    text-align: center;
  }

  .pillar-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(183, 110, 121, 0.12);
    border-color: var(--rose-gold);
  }

  .pillar-card__icon {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    background: linear-gradient(135deg, var(--blush), var(--pink-soft));
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.25rem;
    color: var(--rose-gold);
  }

  .pillar-card__title {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .pillar-card__desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.65;
  }

  /* Detail Blocks */
  .details {
    background: var(--cream);
  }

  .detail-block {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
    padding: 2.5rem;
    margin-bottom: 1.5rem;
    background: var(--white);
    border-radius: 16px;
    border: 1px solid var(--border);
    transition: all 0.3s ease;
  }

  .detail-block:hover {
    box-shadow: 0 8px 30px rgba(183, 110, 121, 0.08);
  }

  .detail-block:last-child {
    margin-bottom: 0;
  }

  .detail-block--alt {
    background: linear-gradient(135deg, var(--white) 0%, var(--blush) 100%);
  }

  .detail-block__number {
    font-family: 'Playfair Display', serif;
    font-size: 3rem;
    font-weight: 700;
    color: var(--rose-gold);
    opacity: 0.3;
    line-height: 1;
    flex-shrink: 0;
    min-width: 60px;
  }

  .detail-block__content {
    flex: 1;
  }

  .detail-block__title {
    font-family: 'Playfair Display', serif;
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .detail-block__text {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.75;
  }

  /* Timeline */
  .timeline-section {
    background: var(--white);
  }

  .timeline {
    position: relative;
    max-width: 700px;
    margin: 0 auto;
    padding-left: 3rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 20px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--rose-gold), var(--pink-soft));
  }

  .timeline__item {
    position: relative;
    margin-bottom: 2.5rem;
    padding-left: 1.5rem;
  }

  .timeline__item:last-child {
    margin-bottom: 0;
  }

  .timeline__marker {
    position: absolute;
    left: -2.35rem;
    top: 0.25rem;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--rose-gold);
    color: var(--white);
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 15px rgba(183, 110, 121, 0.3);
    z-index: 1;
  }

  .timeline__title {
    font-family: 'Playfair Display', serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .timeline__desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.65;
  }

  /* CTA Section */
  .cta-section {
    background: var(--text);
