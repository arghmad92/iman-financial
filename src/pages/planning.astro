---
import Layout from '../layouts/Layout.astro';

const pillars = [
  {
    num: '01',
    title: 'Cash Flow Planning',
    desc: 'Bina foundation kewangan yang kukuh dengan manage income, expenses, savings, dan hutang dengan betul.',
  },
  {
    num: '02',
    title: 'Investment Planning',
    desc: 'Grow your wealth secara strategic dengan portfolio yang tailored ikut risk profile dan long-term goals you.',
  },
  {
    num: '03',
    title: 'Risk Management',
    desc: 'Protect apa yang paling penting dalam hidup you dengan insurance dan takaful coverage yang smart.',
  },
  {
    num: '04',
    title: 'Estate Planning',
    desc: 'Pastikan legacy you selamat dan orang tersayang terjaga, termasuk preparation wasiat dan faraid.',
  },
  {
    num: '05',
    title: 'Goals-Based Planning',
    desc: 'Rumah impian, pendidikan anak, pencen awal, plan setiap milestone dalam hidup you dengan intention.',
  },
  {
    num: '06',
    title: 'Tax Planning',
    desc: 'Strategi tax yang smart, compliant dan selari dengan keperluan you.',
  },
];

const timeline = [
  {
    step: '01',
    title: 'Discovery & Goal-Setting',
    desc: 'Kita mula dengan bincang dengan mendalam tentang hidup you, values, dan apa yang you nak capai dari segi kewangan. Ni masa kita kenal antara satu sama lain.',
  },
  {
    step: '02',
    title: 'Kumpul Data & Analisis',
    desc: 'You share dokumen kewangan, income, expenses, assets, liabilities, insurance policies, dan kita akan analyse semuanya dengan teliti.',
  },
  {
    step: '03',
    title: 'Present Your Financial Plan',
    desc: 'Kita present financial plan yang detailed dan personalised, cover semua 6 pillars, lengkap dengan recommendations yang you boleh terus buat.',
  },
  {
    step: '04',
    title: 'Implementation Support',
    desc: "I takkan bagi plan lepas tu tinggalkan you. Kita akan guide you through setiap step implementation, dari buka akaun sampai adjust coverage.",
  },
  {
    step: '05',
    title: 'Regular Reviews',
    desc: 'Hidup berubah, plan you pun kena ikut. Kita akan regularly review dan adjust plan you bila keadaan you berubah.',
  },
  {
    step: '06',
    title: 'Biannual Check-Ins',
    desc: 'Dua kali setahun, kita duduk untuk comprehensive review, pastikan you on track dan celebrate progress you sama-sama.',
  },
];
---

<Layout title="Full Financial Planning · Iman Abdul Rahim">
  <!-- =================== HERO =================== -->
  <section class="hero">
    <div class="glow glow--a" aria-hidden="true"></div>
    <div class="glow glow--b" aria-hidden="true"></div>

    <div class="container-x hero__inner">
      <span class="eyebrow">Comprehensive Service</span>
      <h1 class="h-display">
        Full Financial<br /><em>Planning.</em>
      </h1>
      <p class="lede hero__lede">
        Engagement setahun yang direka untuk transform setiap aspek kewangan
        you. Kita akan bina plan yang menyeluruh, align duit you dengan
        values, goals, dan impian you.
      </p>
      <div class="hero__actions">
        <a
          href="https://wa.me/60186617981"
          target="_blank"
          rel="noopener"
          class="btn btn--rose btn--lg"
        >
          Book Discovery Call
        </a>
      </div>
    </div>
  </section>

  <!-- =================== PILLARS =================== -->
  <section class="section" id="pillars">
    <div class="container-x">
      <div class="section__intro section__intro--center">
        <span class="eyebrow eyebrow--center">The Framework</span>
        <h2 class="h-section">
          Apa yang termasuk dalam <em>comprehensive planning?</em>
        </h2>
        <p class="lede lede--center">
          The comprehensive planning includes:
        </p>
      </div>

      <ul class="pillars">
        {
          pillars.map((p) => (
            <li class="pillar glass">
              <span class="pillar__num">{p.num}</span>
              <h3 class="pillar__title">{p.title}</h3>
              <p class="pillar__desc">{p.desc}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- =================== TIMELINE =================== -->
  <section class="section">
    <div class="container-tight">
      <div class="section__intro section__intro--center">
        <span class="eyebrow eyebrow--center">The Journey</span>
        <h2 class="h-section">
          Your 12-month <em>anggaran.</em>
        </h2>
        <p class="lede lede--center">
          Macam ni lah journey financial planning you selama setahun, dari
          mula sampai habis.
        </p>
      </div>

      <ol class="timeline">
        {
          timeline.map((t) => (
            <li class="t-item">
              <span class="t-marker glass-pink">{t.step}</span>
              <div class="t-body glass">
                <h4 class="t-title">{t.title}</h4>
                <p class="t-desc">{t.desc}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- =================== CTA =================== -->
  <section class="section cta">
    <div class="container-narrow">
      <div class="cta__card glass-ink">
        <div class="text-center">
          <span class="eyebrow eyebrow--center eyebrow--light">Next step</span>
          <h2 class="h-section cta__title">
            Financial planning yang<br /><em>se-dynamic hidup you.</em>
          </h2>
          <p class="cta__sub">
            Isi borang dibawah untuk book slot &ldquo;Discovery Session&rdquo;.
          </p>
          <div class="cta__actions">
            <a
              href="https://form.wealthvantage.com.my/iman-lead/"
              target="_blank"
              rel="noopener"
              class="btn btn--on-dark btn--lg"
            >
              Book &ldquo;Discovery Session&rdquo;
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* =================== HERO =================== */
  .hero {
    position: relative;
    padding: clamp(8rem, 14vw, 12rem) 0 clamp(4rem, 7vw, 6rem);
    overflow: hidden;
    isolation: isolate;
  }
  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    pointer-events: none;
    z-index: -1;
  }
  .glow--a {
    width: 480px;
    height: 480px;
    top: -120px;
    right: -100px;
    background: radial-gradient(circle, rgba(236, 108, 135, 0.16), transparent 70%);
  }
  .glow--b {
    width: 420px;
    height: 420px;
    bottom: -100px;
    left: -120px;
    background: radial-gradient(circle, rgba(244, 163, 179, 0.14), transparent 70%);
  }
  .hero__inner {
    max-width: 820px;
  }
  .hero__lede {
    margin: 1.5rem 0 2rem;
  }
  .hero__actions {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }
  @media (max-width: 640px) {
    .hero__actions {
      flex-direction: column;
      align-items: stretch;
    }
  }

  /* =================== PILLARS =================== */
  .pillars {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .pillar {
    border-radius: 24px;
    padding: clamp(1.75rem, 3vw, 2.25rem);
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .pillar:hover {
    transform: translateY(-4px);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.6) inset,
      0 24px 56px -16px rgba(200, 70, 104, 0.24);
  }
  .pillar__num {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.05rem;
    color: var(--color-deep);
    font-weight: 400;
    letter-spacing: 0.04em;
  }
  .pillar__title {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-weight: 400;
    color: var(--color-ink);
    letter-spacing: -0.02em;
  }
  .pillar__desc {
    font-size: 0.93rem;
    color: var(--color-ink-2);
    line-height: 1.7;
  }
  @media (max-width: 900px) {
    .pillars { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 580px) {
    .pillars { grid-template-columns: 1fr; }
  }

  /* =================== TIMELINE =================== */
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0 auto;
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .t-item {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 1.25rem;
    align-items: stretch;
  }
  .t-marker {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    color: var(--color-deep);
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    letter-spacing: 0;
  }
  .t-body {
    border-radius: 20px;
    padding: 1.4rem 1.6rem;
  }
  .t-title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--color-ink);
    letter-spacing: -0.02em;
    margin-bottom: 0.4rem;
  }
  .t-desc {
    font-size: 0.95rem;
    color: var(--color-ink-2);
    line-height: 1.7;
  }

  /* =================== CTA =================== */
  .cta__card {
    border-radius: 32px;
    padding: clamp(2.5rem, 5vw, 4rem) clamp(1.75rem, 4vw, 3rem);
  }
  .cta__title {
    color: var(--color-paper);
  }
  .cta__title em {
    color: var(--color-rose);
  }
  .cta__sub {
    color: rgba(255, 250, 251, 0.78);
    font-size: 1rem;
    line-height: 1.7;
    margin: 1.25rem auto 2.25rem;
    max-width: 48ch;
  }
  .cta__actions {
    display: flex;
    gap: 0.8rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  @media (max-width: 560px) {
    .cta__actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
