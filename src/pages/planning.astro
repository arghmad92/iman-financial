---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Full Financial Planning — Iman Abdul Rahim">
  <!-- Hero Section -->
  <section class="section hero">
    <div class="container">
      <div class="hero__badge">Comprehensive Service</div>
      <h1 class="hero__title">Full Financial Planning</h1>
      <p class="hero__subtitle">
        A comprehensive 1-year engagement designed to transform every aspect of your financial life.
        Together, we'll build a holistic plan that aligns your money with your values, goals, and dreams.
      </p>
      <div class="hero__actions">
        <a href="https://wa.me/60186617981" class="btn btn--primary" target="_blank" rel="noopener noreferrer">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Book a Discovery Call
        </a>
        <a href="#pillars" class="btn btn--outline">Explore the Pillars</a>
      </div>
    </div>
  </section>

  <!-- 6 Planning Pillars -->
  <section class="section pillars" id="pillars">
    <div class="container">
      <div class="section__header">
        <h2 class="section__title">The 6 Pillars of Your Financial Plan</h2>
        <p class="section__subtitle">Every great financial plan is built on a solid foundation. Here are the six pillars we'll work through together.</p>
      </div>
      <div class="pillars__grid">
        <div class="card pillar-card">
          <div class="pillar-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <h3 class="pillar-card__title">Cash Flow Planning</h3>
          <p class="pillar-card__desc">Build a strong financial foundation by managing income, expenses, savings, and debt effectively.</p>
        </div>
        <div class="card pillar-card">
          <div class="pillar-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <h3 class="pillar-card__title">Investment Planning</h3>
          <p class="pillar-card__desc">Grow wealth strategically with portfolios tailored to your risk profile and long-term goals.</p>
        </div>
        <div class="card pillar-card">
          <div class="pillar-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 class="pillar-card__title">Risk Management</h3>
          <p class="pillar-card__desc">Protect what matters most with smart insurance and takaful coverage solutions.</p>
        </div>
        <div class="card pillar-card">
          <div class="pillar-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <h3 class="pillar-card__title">Estate Planning</h3>
          <p class="pillar-card__desc">Secure your legacy and ensure your loved ones are taken care of, including wasiat preparation.</p>
        </div>
        <div class="card pillar-card">
          <div class="pillar-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3 class="pillar-card__title">Goals-Based Planning</h3>
          <p class="pillar-card__desc">Dream home, children's education, early retirement — plan every milestone with intention.</p>
        </div>
        <div class="card pillar-card">
          <div class="pillar-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
          </div>
          <h3 class="pillar-card__title">Tax Planning</h3>
          <p class="pillar-card__desc">Maximize your wealth with smart, compliant tax strategies and optimizations.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Detailed Pillar Sections -->
  <section class="section details">
    <div class="container">
      <div class="section__header">
        <h2 class="section__title">A Closer Look at Each Pillar</h2>
        <p class="section__subtitle">Discover how each area of planning works together to create a complete financial picture.</p>
      </div>

      <div class="detail-block">
        <div class="detail-block__number">01</div>
        <div class="detail-block__content">
          <h3 class="detail-block__title">Cash Flow Management</h3>
          <p class="detail-block__text">
            Cash flow is the heartbeat of your financial plan. We'll map out every ringgit coming in and going out,
            identify areas for improvement, and create a sustainable system that ensures you're saving consistently,
            paying down debt strategically, and building an emergency fund that gives you peace of mind. This is
            where financial clarity begins.
          </p>
        </div>
      </div>

      <div class="detail-block detail-block--alt">
        <div class="detail-block__number">02</div>
        <div class="detail-block__content">
          <h3 class="detail-block__title">Investment Planning</h3>
          <p class="detail-block__text">
            Growing your wealth requires more than just picking the right products — it requires a strategy.
            We'll assess your risk tolerance, time horizon, and financial goals to build a diversified portfolio
            that works for you. From unit trusts and ETFs to EPF optimization and Shariah-compliant options,
            your investment plan will be as unique as your aspirations.
          </p>
        </div>
      </div>

      <div class="detail-block">
        <div class="detail-block__number">03</div>
        <div class="detail-block__content">
          <h3 class="detail-block__title">Wealth Protection</h3>
          <p class="detail-block__text">
            Life is unpredictable. Risk management through insurance and takaful ensures that an unexpected event
            doesn't derail your financial progress. We'll review your current coverage, identify gaps, and recommend
            solutions that protect your income, health, and family — without over-insuring or wasting premiums.
          </p>
        </div>
      </div>

      <div class="detail-block detail-block--alt">
        <div class="detail-block__number">04</div>
        <div class="detail-block__content">
          <h3 class="detail-block__title">Estate Planning</h3>
          <p class="detail-block__text">
            Estate planning isn't just for the wealthy — it's for anyone who wants to ensure their assets are
            distributed according to their wishes. We'll help you set up a wasiat (Islamic will), understand
            faraid implications, and create a plan that protects your loved ones and preserves your legacy
            for generations to come.
          </p>
        </div>
      </div>

      <div class="detail-block">
        <div class="detail-block__number">05</div>
        <div class="detail-block__content">
          <h3 class="detail-block__title">Retirement Planning</h3>
          <p class="detail-block__text">
            When do you want to retire? What does your ideal retirement look like? We'll calculate the numbers,
            build a savings trajectory, and create an investment strategy that gets you there. Whether you dream
            of early retirement at 45 or a comfortable life after 60, we'll map out the path and track your
            progress every step of the way.
          </p>
        </div>
      </div>

      <div class="detail-block detail-block--alt">
        <div class="detail-block__number">06</div>
        <div class="detail-block__content">
          <h3 class="detail-block__title">Tax Planning</h3>
          <p class="detail-block__text">
            Every ringgit saved on taxes is a ringgit that can be redirected toward your goals. We'll review your
            tax situation, identify eligible reliefs and deductions, and implement strategies to minimize your tax
            burden legally and ethically. From PRS contributions to education deductions, we'll make sure you're
            keeping more of what you earn.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Engagement Timeline -->
  <section class="section timeline-section">
    <div class="container">
      <div class="section__header">
        <h2 class="section__title">Typical Engagement Timeline</h2>
        <p class="section__subtitle">Here's what your 1-year financial planning journey looks like from start to finish.</p>
      </div>
      <div class="timeline">
        <div class="timeline__item">
          <div class="timeline__marker">1</div>
          <div class="timeline__content">
            <h4 class="timeline__title">Initial Discovery &amp; Goal-Setting Session</h4>
            <p class="timeline__desc">We begin with an in-depth conversation about your life, values, and financial aspirations. This is where we truly get to know each other.</p>
          </div>
        </div>
        <div class="timeline__item">
          <div class="timeline__marker">2</div>
          <div class="timeline__content">
            <h4 class="timeline__title">Data Gathering &amp; Analysis</h4>
            <p class="timeline__desc">You'll share your financial documents — income, expenses, assets, liabilities, insurance policies — and we'll analyse everything thoroughly.</p>
          </div>
        </div>
        <div class="timeline__item">
          <div class="timeline__marker">3</div>
          <div class="timeline__content">
            <h4 class="timeline__title">Comprehensive Financial Plan Presentation</h4>
            <p class="timeline__desc">We present a detailed, personalised financial plan covering all six pillars, complete with actionable recommendations.</p>
          </div>
        </div>
        <div class="timeline__item">
          <div class="timeline__marker">4</div>
          <div class="timeline__content">
            <h4 class="timeline__title">Implementation Support</h4>
            <p class="timeline__desc">We don't just hand you a plan and walk away. We'll guide you through every step of implementation — from opening accounts to adjusting coverage.</p>
          </div>
        </div>
        <div class="timeline__item">
          <div class="timeline__marker">5</div>
          <div class="timeline__content">
            <h4 class="timeline__title">Ongoing Reviews &amp; Plan Updates</h4>
            <p class="timeline__desc">Life changes, and your plan should too. We'll regularly review and adjust your plan as your circumstances evolve.</p>
          </div>
        </div>
        <div class="timeline__item">
          <div class="timeline__marker">6</div>
          <div class="timeline__content">
            <h4 class="timeline__title">Semi-Annual Check-Ins</h4>
            <p class="timeline__desc">Twice a year, we'll sit down for a comprehensive review to ensure you're on track and celebrate your progress.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section cta-section">
    <div class="container">
      <div class="cta-block">
        <h2 class="cta-block__title">Experience financial planning that's as dynamic as your life</h2>
        <p class="cta-block__text">
          Ready to take control of your financial future? Let's start with a conversation.
        </p>
        <a href="https://wa.me/60186617981" class="btn btn--primary btn--lg" target="_blank" rel="noopener noreferrer">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Chat on WhatsApp
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero Section */
  .hero {
    text-align: center;
    padding: 6rem 1.5rem 4rem;
    background: linear-gradient(135deg, var(--cream) 0%, var(--blush) 50%, var(--pink-soft) 100%);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--rose-gold) 0%, transparent 70%);
    opacity: 0.08;
    pointer-events: none;
  }

  .hero__badge {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    background: rgba(183, 110, 121, 0.1);
    border: 1px solid var(--rose-gold);
    border-radius: 50px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--rose-gold);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .hero__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    color: var(--text);
    margin-bottom: 1.25rem;
    line-height: 1.15;
  }

  .hero__subtitle {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.15rem;
    color: var(--text-secondary);
    max-width: 640px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    border-radius: 50px;
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
    border: none;
  }

  .btn--primary {
    background: var(--rose-gold);
    color: var(--white);
    box-shadow: 0 4px 20px rgba(183, 110, 121, 0.3);
  }

  .btn--primary:hover {
    background: var(--pink);
    transform: translateY(-2px);
    box-shadow: 0 6px 25px rgba(183, 110, 121, 0.4);
  }

  .btn--outline {
    background: transparent;
    color: var(--rose-gold);
    border: 2px solid var(--rose-gold);
  }

  .btn--outline:hover {
    background: var(--rose-gold);
    color: var(--white);
    transform: translateY(-2px);
  }

  .btn--lg {
    padding: 1rem 2.5rem;
    font-size: 1.1rem;
  }

  /* Section Styles */
  .section {
    padding: 5rem 1.5rem;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section__header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .section__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    color: var(--text);
    margin-bottom: 1rem;
  }

  .section__subtitle {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.05rem;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Pillars Grid */
  .pillars {
    background: var(--white);
  }

  .pillars__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .pillar-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
    transition: all 0.3s ease;
    text-align: center;
  }

  .pillar-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(183, 110, 121, 0.12);
    border-color: var(--rose-gold);
  }

  .pillar-card__icon {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    background: linear-gradient(135deg, var(--blush), var(--pink-soft));
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.25rem;
    color: var(--rose-gold);
  }

  .pillar-card__title {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .pillar-card__desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.65;
  }

  /* Detail Blocks */
  .details {
    background: var(--cream);
  }

  .detail-block {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
    padding: 2.5rem;
    margin-bottom: 1.5rem;
    background: var(--white);
    border-radius: 16px;
    border: 1px solid var(--border);
    transition: all 0.3s ease;
  }

  .detail-block:hover {
    box-shadow: 0 8px 30px rgba(183, 110, 121, 0.08);
  }

  .detail-block:last-child {
    margin-bottom: 0;
  }

  .detail-block--alt {
    background: linear-gradient(135deg, var(--white) 0%, var(--blush) 100%);
  }

  .detail-block__number {
    font-family: 'Playfair Display', serif;
    font-size: 3rem;
    font-weight: 700;
    color: var(--rose-gold);
    opacity: 0.3;
    line-height: 1;
    flex-shrink: 0;
    min-width: 60px;
  }

  .detail-block__content {
    flex: 1;
  }

  .detail-block__title {
    font-family: 'Playfair Display', serif;
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .detail-block__text {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.75;
  }

  /* Timeline */
  .timeline-section {
    background: var(--white);
  }

  .timeline {
    position: relative;
    max-width: 700px;
    margin: 0 auto;
    padding-left: 3rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 20px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--rose-gold), var(--pink-soft));
  }

  .timeline__item {
    position: relative;
    margin-bottom: 2.5rem;
    padding-left: 1.5rem;
  }

  .timeline__item:last-child {
    margin-bottom: 0;
  }

  .timeline__marker {
    position: absolute;
    left: -2.35rem;
    top: 0.25rem;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--rose-gold);
    color: var(--white);
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 15px rgba(183, 110, 121, 0.3);
    z-index: 1;
  }

  .timeline__title {
    font-family: 'Playfair Display', serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .timeline__desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.65;
  }

  /* CTA Section */
  .cta-section {
    background: var(--text);
    padding: 5rem 1.5rem;
  }

  .cta-block {
    text-align: center;
    max-width: 650px;
    margin: 0 auto;
  }

  .cta-block__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.75rem, 3.5vw, 2.25rem);
    font-weight: 700;
    color: var(--white);
    margin-bottom: 1.25rem;
    line-height: 1.3;
  }

  .cta-block__text {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .cta-section .btn--primary {
    background: var(--rose-gold);
    color: var(--white);
  }

  .cta-section .btn--primary:hover {
    background: var(--gold);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .pillars__grid {
      grid-template-columns: 1fr;
