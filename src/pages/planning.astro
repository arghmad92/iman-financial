---
import Layout from '../layouts/Layout.astro';

const pillars = [
  { num: '01', title: 'Cash Flow Planning', desc: 'Bina foundation kewangan yang kukuh dengan manage income, expenses, savings, dan hutang dengan betul.' },
  { num: '02', title: 'Investment Planning', desc: 'Grow your wealth secara strategic dengan portfolio yang tailored ikut risk profile dan long-term goals you.' },
  { num: '03', title: 'Risk Management', desc: 'Protect apa yang paling penting dalam hidup you dengan insurance dan takaful coverage yang smart.' },
  { num: '04', title: 'Estate Planning', desc: 'Pastikan legacy you selamat dan orang tersayang terjaga, termasuk preparation wasiat dan faraid.' },
  { num: '05', title: 'Goals-Based Planning', desc: 'Rumah impian, pendidikan anak, pencen awal, plan setiap milestone dalam hidup you dengan intention.' },
  { num: '06', title: 'Tax Planning', desc: 'Strategi tax yang smart, compliant dan selari dengan keperluan you.' },
];

const timeline = [
  { step: '01', title: 'Discovery & Goal-Setting', desc: 'Kita mula dengan bincang dengan mendalam tentang hidup you, values, dan apa yang you nak capai dari segi kewangan. Ni masa kita kenal antara satu sama lain.' },
  { step: '02', title: 'Kumpul Data & Analisis', desc: 'You share dokumen kewangan, income, expenses, assets, liabilities, insurance policies, dan kita akan analyse semuanya dengan teliti.' },
  { step: '03', title: 'Present Your Financial Plan', desc: 'Kita present financial plan yang detailed dan personalised, cover semua 6 pillars, lengkap dengan recommendations yang you boleh terus buat.' },
  { step: '04', title: 'Implementation Support', desc: "I takkan bagi plan lepas tu tinggalkan you. Kita akan guide you through setiap step implementation, dari buka akaun sampai adjust coverage." },
  { step: '05', title: 'Regular Reviews', desc: 'Hidup berubah, plan you pun kena ikut. Kita akan regularly review dan adjust plan you bila keadaan you berubah.' },
  { step: '06', title: 'Biannual Check-Ins', desc: 'Dua kali setahun, kita duduk untuk comprehensive review, pastikan you on track dan celebrate progress you sama-sama.' },
];
---

<Layout title="Full Financial Planning · Iman Abdul Rahim">
  <!-- =================== HERO =================== -->
  <section class="hero">
    <div class="container-x hero__inner">
      <span class="hero__eyebrow">Comprehensive Service · 12 months</span>
      <h1 class="h-display hero__title text-balance">
        Full Financial<br /><span class="pink">Planning.</span>
      </h1>
      <p class="lede lede--xl lede--center hero__lede text-balance">
        Engagement setahun yang direka untuk transform setiap aspek kewangan
        you. Kita akan bina plan yang menyeluruh, align duit you dengan values,
        goals, dan impian you.
      </p>
      <div class="hero__actions">
        <a
          href="https://form.wealthvantage.com.my/iman-lead/"
          target="_blank"
          rel="noopener"
          class="btn btn--primary btn--lg"
        >
          Book Discovery Call
        </a>
        <a href="#pillars" class="btn btn--glass btn--lg btn--arrow">
          See framework
        </a>
      </div>
    </div>
  </section>

  <!-- =================== PILLARS — bento 3x2 =================== -->
  <section class="section" id="pillars">
    <div class="container-x">
      <div class="sec-head text-center">
        <span class="eyebrow eyebrow--center">The Framework</span>
        <h2 class="h-section text-balance">
          Apa yang termasuk dalam <span class="pink">comprehensive planning?</span>
        </h2>
        <p class="lede lede--center">The comprehensive planning includes:</p>
      </div>

      <ul class="bento">
        {pillars.map((p) => (
          <li class="bento__card">
            <span class="bento__num">{p.num}</span>
            <h3 class="bento__title">{p.title}</h3>
            <p class="bento__desc">{p.desc}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- =================== TIMELINE =================== -->
  <section class="section">
    <div class="container-tight">
      <div class="sec-head text-center">
        <span class="eyebrow eyebrow--center">The Journey</span>
        <h2 class="h-section text-balance">
          Your 12-month <span class="pink">anggaran.</span>
        </h2>
        <p class="lede lede--center">
          Macam ni lah journey financial planning you selama setahun, dari mula
          sampai habis.
        </p>
      </div>

      <ol class="tl">
        {timeline.map((t, idx) => (
          <li class="tl__row">
            <div class="tl__marker">
              <span class="tl__step">{t.step}</span>
              {idx < timeline.length - 1 && <span class="tl__line" aria-hidden="true" />}
            </div>
            <div class="tl__body">
              <h3 class="tl__title">{t.title}</h3>
              <p class="tl__desc">{t.desc}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- =================== CTA =================== -->
  <section class="section">
    <div class="container-narrow">
      <div class="cta-card">
        <span class="eyebrow">Next step</span>
        <h2 class="h-section cta-card__title text-balance">
          Financial planning yang <span class="cta-pink">se-dynamic hidup you.</span>
        </h2>
        <p class="cta-card__sub">
          Isi borang dibawah untuk book slot &ldquo;Discovery Session&rdquo;.
        </p>
        <a
          href="https://form.wealthvantage.com.my/iman-lead/"
          target="_blank"
          rel="noopener"
          class="btn btn--ink btn--lg btn--arrow"
        >
          Book &ldquo;Discovery Session&rdquo;
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding: clamp(3rem, 6vw, 6rem) 0 clamp(4rem, 7vw, 7rem);
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }
  .hero__glow-a {
    width: 640px;
    height: 640px;
    top: -180px;
    right: -160px;
    background: radial-gradient(circle, rgba(196, 69, 105, 0.07), transparent 65%);
    z-index: -1;
  }
  .hero__glow-b {
    width: 520px;
    height: 520px;
    bottom: -160px;
    left: -160px;
    background: radial-gradient(circle, rgba(249, 212, 220, 0.22), transparent 65%);
    z-index: -1;
  }
  .hero__inner {
    text-align: center;
    position: relative;
    z-index: 1;
  }
  .hero__eyebrow {
    display: inline-block;
    padding: 0.45rem 1rem;
    background: var(--glass-strong);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-primary);
    margin-bottom: 1.75rem;
    box-shadow: var(--shadow-glass);
  }
  .hero__title {
    margin: 0 auto;
  }
  .hero__lede {
    margin: 1.75rem auto 0;
  }
  .hero__actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 2.5rem;
  }

  .sec-head {
    max-width: 760px;
    margin-bottom: clamp(3rem, 5vw, 4.5rem);
  }
  .sec-head.text-center {
    margin-left: auto;
    margin-right: auto;
  }
  .sec-head .h-section {
    margin-top: 1rem;
  }
  .sec-head .lede {
    margin-top: 1.25rem;
  }
  .sec-head.text-center .lede {
    margin-left: auto;
    margin-right: auto;
  }

  /* Bento 3x2 */
  .bento {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1rem, 2vw, 1.4rem);
  }
  .bento__card {
    background: var(--glass-strong);
    backdrop-filter: var(--glass-blur-strong);
    -webkit-backdrop-filter: var(--glass-blur-strong);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-2xl);
    padding: clamp(1.75rem, 3vw, 2.25rem);
    box-shadow: var(--shadow-glass);
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }
  .bento__num {
    display: inline-block;
    padding: 0.32rem 0.7rem;
    background: var(--color-primary);
    color: var(--color-paper);
    font-size: 0.78rem;
    font-weight: 600;
    border-radius: 999px;
    letter-spacing: -0.005em;
    font-variant-numeric: tabular-nums;
    margin-bottom: 1.25rem;
  }
  .bento__title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--color-foreground);
    margin: 0 0 0.75rem;
    line-height: 1.1;
  }
  .bento__desc {
    font-size: 0.95rem;
    color: var(--color-ink-2);
    line-height: 1.65;
    margin: 0;
  }
  @media (max-width: 900px) {
    .bento { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .bento { grid-template-columns: 1fr; }
  }

  /* Timeline */
  .tl {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }
  .tl__row {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 1.5rem;
  }
  .tl__marker {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .tl__step {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--glass-strong);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    color: var(--color-primary);
    border: 1px solid var(--glass-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    flex-shrink: 0;
    box-shadow: var(--shadow-glass);
    font-variant-numeric: tabular-nums;
  }
  .tl__line {
    flex: 1;
    width: 1.5px;
    background: var(--glass-border-pink);
    margin: 0.4rem 0;
  }
  .tl__body {
    padding: 0.4rem 0 2.5rem;
  }
  .tl__title {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2vw, 1.65rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--color-foreground);
    margin: 0 0 0.5rem;
    line-height: 1.1;
  }
  .tl__desc {
    font-size: 0.98rem;
    color: var(--color-ink-2);
    line-height: 1.65;
    margin: 0;
    max-width: 60ch;
  }

  /* CTA — pink panel with layered gradient */
  .cta-card {
    background: var(--gradient-pink-panel);
    color: var(--color-foreground);
    border: 1px solid rgba(196, 69, 105, 0.14);
    border-radius: var(--radius-3xl);
    padding: clamp(2.5rem, 5vw, 4rem) clamp(2rem, 4vw, 3rem);
    text-align: center;
    box-shadow: var(--gradient-pink-panel-shadow);
  }
  .cta-card .eyebrow {
    justify-content: center;
  }
  .cta-card__title {
    color: var(--color-foreground);
    margin: 1rem 0 1.5rem;
  }
  .cta-pink {
    color: var(--color-primary);
  }
  .cta-card__sub {
    color: var(--color-ink-2);
    font-size: 1.05rem;
    line-height: 1.6;
    margin: 0 auto 2rem;
    max-width: 48ch;
  }
</style>
