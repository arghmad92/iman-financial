---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Iman Abdul Rahim · Licensed Financial Planner | CFP® | IFP">
  <!-- =================== HERO =================== -->
  <section class="hero">
    <div class="glow glow--a" aria-hidden="true"></div>
    <div class="glow glow--b" aria-hidden="true"></div>

    <div class="container-x hero__inner">
      <span class="eyebrow">Licensed Financial Planner · CFP® · IFP</span>
      <h1 class="h-display hero__title">
        Nak rancang kewangan?<br />
        <em>Jom buat betul-betul.</em>
      </h1>
      <p class="lede hero__lede">
        I bantu ladies macam you urus kewangan dengan strategi yang jelas dan
        nasihat yang personalised, tanpa bias, supaya you boleh buat keputusan
        kewangan dengan yakin, bijak, dan terancang.
      </p>

      <div class="hero__orb glass-pink" aria-hidden="true">
        <svg viewBox="0 0 200 200" width="100%" height="100%">
          <circle cx="100" cy="100" r="92" fill="none" stroke="currentColor" stroke-width="0.5" />
          <circle cx="100" cy="100" r="68" fill="none" stroke="currentColor" stroke-width="0.5" />
          <circle cx="100" cy="100" r="44" fill="none" stroke="currentColor" stroke-width="0.5" />
          <circle cx="100" cy="100" r="20" fill="none" stroke="currentColor" stroke-width="0.5" />
        </svg>
      </div>
    </div>
  </section>

  <!-- =================== SERVICES =================== -->
  <section class="section" id="services">
    <div class="container-x">
      <div class="section__intro">
        <span class="eyebrow">Services</span>
        <h2 class="h-section">
          Macam mana I boleh <em>bantu you.</em>
        </h2>
        <p class="lede">
          Dua cara untuk start financial planning journey you, pilih yang
          sesuai dengan keperluan you.
        </p>
      </div>

      <div class="services">
        <a href="/planning" class="service glass">
          <div class="service__body">
            <span class="chip chip--rose">12-month engagement</span>
            <h3 class="service__title">Full Financial Planning</h3>
            <p class="service__desc">
              Engagement setahun yang cover semua aspek kewangan you secara
              menyeluruh, daripada A to Z. Semua strategi dan solusi akan
              di-customise ikut goals you, supaya kewangan you lebih tersusun,
              jelas, dan on track untuk jangka masa panjang.
            </p>
          </div>
          <div class="service__foot">
            <span class="service__price">
              <span class="service__price-amt">RM 3,500</span>
              <span class="service__price-note">12-month</span>
            </span>
            <span class="service__cta">
              Baca lagi <span aria-hidden="true">→</span>
            </span>
          </div>
        </a>

        <a href="/fhc" class="service service--featured glass-ink">
          <div class="service__body">
            <span class="chip chip--on-dark">One-time review</span>
            <h3 class="service__title">Financial Health Check</h3>
            <p class="service__desc">
              One-time financial review untuk check keadaan kewangan you secara
              menyeluruh. You akan dapat insights yang jelas, objective, dan
              tanpa product push, supaya you tahu apa yang dah okay, apa yang
              perlu diperbaiki, dan macam mana nak betulkan.
            </p>
          </div>
          <div class="service__foot">
            <span class="service__price">
              <span class="service__price-amt">RM 350</span>
              <span class="service__price-note">One-time</span>
            </span>
            <span class="service__cta">
              Book now <span aria-hidden="true">→</span>
            </span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- =================== ABOUT / PHILOSOPHY =================== -->
  <section class="section" id="about">
    <div class="container-x about">
      <div class="about__content">
        <span class="eyebrow">About</span>
        <h2 class="h-section">
          Kewangan you deserve<br />
          <em>nasihat yang betul.</em>
        </h2>
        <p class="about__text">
          I'm Iman Abdul Rahim, Licensed Financial Planner dengan pengalaman
          5 tahun tolong Malaysians macam you take control of duit sendiri.
        </p>
        <p class="about__text">
          I licensed dengan Securities Commission Malaysia dan Bank Negara
          Malaysia, dan I pegang CFP® dan Islamic Financial Planner (IFP)
          certifications. I terikat dengan ethical codes dan fiduciary
          standards. Maknanya, I kena <em>always</em> act in your best interest.
        </p>
      </div>
    </div>
  </section>

  <!-- =================== FAQ =================== -->
  <section class="section" id="faq">
    <div class="container-tight">
      <div class="faq-card glass">
        <div class="section__intro">
          <span class="eyebrow">FAQ</span>
          <h2 class="h-section">
            Soalan <em>lazim.</em>
          </h2>
        </div>

        <div class="faq">
          <details>
            <summary>Financial Planner ni buat apa sebenarnya?</summary>
            <div class="faq__a">
              <p>
                Licensed Financial Planner tolong individuals dan families buat
                keputusan kewangan yang informed supaya boleh capai life goals, melalui nasihat yang personalised dan structured.
              </p>
              <p>
                Nasihat I always in your best interest, bukan nak push product. I
                juga tolong dengan implementation dan buat regular reviews supaya
                you stay on track.
              </p>
            </div>
          </details>

          <details>
            <summary>Nasihat ni Shariah compliant ke?</summary>
            <div class="faq__a">
              <p>
                Yes, memang. I offer Shariah-compliant financial planning,
                termasuk Islamic investment portfolios, takaful, dan zakat
                planning. You boleh request supaya seluruh financial plan you
                Shariah-aligned.
              </p>
            </div>
          </details>

          <details>
            <summary>Info I confidential ke?</summary>
            <div class="faq__a">
              <p>
                Mestilah. I comply dengan PDPA regulations dan jaga
                confidentiality you dengan ketat. Semua data yang you share
                disimpan securely dan hanya digunakan untuk planning purposes
                dengan consent you.
              </p>
            </div>
          </details>

          <details>
            <summary>Berapa kos financial planning ni?</summary>
            <div class="faq__a">
              <p>
                Financial Health Check tu one-time session je, RM 350. Full
                Financial Planning pulak engagement 12 bulan, fees kita discuss
                masa initial consultation based on complexity. Jom book free
                discovery call dulu untuk tahu lebih lanjut.
              </p>
            </div>
          </details>

          <details>
            <summary>I baru grad, sesuai ke untuk I?</summary>
            <div class="faq__a">
              <p>
                Memang sesuai lah! Financial Health Check ni perfect untuk
                sesiapa yang baru nak start financial journey. You akan dapat
                clarity tentang where you stand sekarang dan actionable steps
                untuk move forward dengan yakin.
              </p>
            </div>
          </details>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* =================== HERO =================== */
  .hero {
    position: relative;
    padding: clamp(8rem, 14vw, 12rem) 0 clamp(4.5rem, 8vw, 7rem);
    overflow: hidden;
    isolation: isolate;
  }
  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    pointer-events: none;
    z-index: -1;
  }
  .glow--a {
    width: 520px;
    height: 520px;
    top: -120px;
    right: -100px;
    background: radial-gradient(circle, rgba(236, 108, 135, 0.16), transparent 70%);
  }
  .glow--b {
    width: 420px;
    height: 420px;
    bottom: -120px;
    left: -100px;
    background: radial-gradient(circle, rgba(244, 163, 179, 0.14), transparent 70%);
  }
  .hero__inner {
    position: relative;
    max-width: 1180px;
    display: grid;
    grid-template-columns: 1fr;
  }
  .hero__title { margin: 1.25rem 0 1.5rem; max-width: 18ch; }
  .hero__lede { font-size: clamp(1.05rem, 1.4vw, 1.2rem); }
  .hero__orb {
    position: absolute;
    right: clamp(-3rem, -2vw, -1rem);
    top: 50%;
    transform: translateY(-50%);
    width: clamp(280px, 40vw, 460px);
    aspect-ratio: 1;
    border-radius: 50%;
    color: var(--color-rose);
    z-index: -1;
    display: grid;
    place-items: center;
    padding: clamp(1.25rem, 3vw, 2.5rem);
  }
  @media (max-width: 980px) {
    .hero__orb {
      right: -10rem;
      opacity: 0.55;
    }
  }
  @media (max-width: 640px) {
    .hero__orb {
      right: -14rem;
      width: 280px;
      opacity: 0.4;
    }
  }

  /* =================== SERVICES =================== */
  .services {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  .service {
    display: flex;
    flex-direction: column;
    border-radius: 28px;
    padding: clamp(1.75rem, 3vw, 2.5rem);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    position: relative;
    overflow: hidden;
  }
  .service:hover {
    transform: translateY(-4px);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.6) inset,
      0 24px 56px -16px rgba(200, 70, 104, 0.28);
  }
  .service--featured {
    color: var(--color-paper);
  }
  .service__body {
    display: flex;
    flex-direction: column;
    gap: 0.95rem;
    flex-grow: 1;
  }
  .service__title {
    font-size: clamp(1.45rem, 2.2vw, 1.8rem);
    font-weight: 400;
    margin-top: 0.2rem;
    color: inherit;
  }
  .service__desc {
    font-size: 0.96rem;
    color: var(--color-ink-2);
    line-height: 1.7;
  }
  .service--featured .service__desc {
    color: rgba(255, 250, 251, 0.78);
  }
  .service__foot {
    margin-top: 2rem;
    padding-top: 1.4rem;
    border-top: 1px solid var(--color-hairline);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }
  .service--featured .service__foot {
    border-top-color: rgba(255, 250, 251, 0.12);
  }
  .service__price {
    display: flex;
    flex-direction: column;
    line-height: 1;
    gap: 0.3rem;
  }
  .service__price-amt {
    font-family: var(--font-serif);
    font-size: 1.7rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: inherit;
  }
  .service__price-note {
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-3);
  }
  .service--featured .service__price-note {
    color: rgba(255, 250, 251, 0.55);
  }
  .service__cta {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--color-deep);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: gap 0.2s ease;
  }
  .service--featured .service__cta {
    color: var(--color-rose);
  }
  .service:hover .service__cta {
    gap: 0.7rem;
  }
  @media (max-width: 860px) {
    .services { grid-template-columns: 1fr; }
  }

  /* =================== ABOUT =================== */
  .about__content {
    max-width: 640px;
  }
  .about__text {
    font-size: 1rem;
    color: var(--color-ink-2);
    line-height: 1.8;
    margin-top: 1rem;
  }
  .about__text em {
    font-style: italic;
    color: var(--color-deep);
  }

  /* =================== FAQ =================== */
  .faq-card {
    border-radius: 32px;
    padding: clamp(2rem, 4vw, 3.5rem);
  }
</style>
