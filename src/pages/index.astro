---
import Layout from '../layouts/Layout.astro';
import Accordion from '../components/Accordion.astro';

const faqs = [
  {
    q: 'Financial Planner ni buat apa sebenarnya?',
    a: [
      'Licensed Financial Planner tolong individuals dan families buat keputusan kewangan yang informed supaya boleh capai life goals, melalui nasihat yang personalised dan structured.',
      'Nasihat I always in your best interest, bukan nak push product. I juga tolong dengan implementation dan buat regular reviews supaya you stay on track.',
    ],
  },
  {
    q: 'Nasihat ni Shariah compliant ke?',
    a: 'Yes, memang. I offer Shariah-compliant financial planning, termasuk Islamic investment portfolios, takaful, dan zakat planning. You boleh request supaya seluruh financial plan you Shariah-aligned.',
  },
  {
    q: 'Info I confidential ke?',
    a: 'Mestilah. I comply dengan PDPA regulations dan jaga confidentiality you dengan ketat. Semua data yang you share disimpan securely dan hanya digunakan untuk planning purposes dengan consent you.',
  },
  {
    q: 'Berapa kos financial planning ni?',
    a: 'Financial Health Check tu one-time session je, RM 350. Full Financial Planning pulak engagement 12 bulan, fees kita discuss masa initial consultation based on complexity. Jom book free discovery call dulu untuk tahu lebih lanjut.',
  },
  {
    q: 'I baru grad, sesuai ke untuk I?',
    a: 'Memang sesuai lah! Financial Health Check ni perfect untuk sesiapa yang baru nak start financial journey. You akan dapat clarity tentang where you stand sekarang dan actionable steps untuk move forward dengan yakin.',
  },
];
---

<Layout title="Iman Abdul Rahim · Licensed Financial Planner | CFP® | IFP">
  <!-- =================== HERO =================== -->
  <section class="hero">
    <div class="glow hero__glow-a" aria-hidden="true"></div>
    <div class="glow hero__glow-b" aria-hidden="true"></div>

    <div class="container-x hero__inner">
      <span class="hero__eyebrow">Licensed Financial Planner · CFP® · IFP</span>
      <h1 class="h-display h-display--xl hero__title text-balance">
        Nak rancang kewangan?<br />
        <span class="pink">Jom buat betul-betul.</span>
      </h1>
      <p class="lede lede--xl lede--center hero__lede text-balance">
        Nasihat personalised, tanpa bias, untuk ladies Malaysia yang nak
        buat keputusan kewangan dengan yakin.
      </p>
      <div class="hero__actions">
        <a
          href="https://form.wealthvantage.com.my/iman-lead/"
          target="_blank"
          rel="noopener"
          class="btn btn--primary btn--lg"
        >
          Book a call
        </a>
        <a href="#services" class="btn btn--glass btn--lg btn--arrow">
          See services
        </a>
      </div>
    </div>

    <!-- Trust card — Apple-style "specs strip" -->
    <div class="container-x">
      <div class="trust">
        <div class="trust__item">
          <span class="trust__label">Licensed by</span>
          <span class="trust__val">SC &amp; BNM</span>
        </div>
        <div class="trust__item">
          <span class="trust__label">Certifications</span>
          <span class="trust__val">CFP® &middot; IFP</span>
        </div>
        <div class="trust__item">
          <span class="trust__label">Experience</span>
          <span class="trust__val"><span data-count-to="5">0</span> years</span>
        </div>
        <div class="trust__item">
          <span class="trust__label">Approach</span>
          <span class="trust__val">Fiduciary</span>
        </div>
      </div>
    </div>
  </section>

  <!-- =================== SERVICES =================== -->
  <section class="section" id="services">
    <div class="container-x">
      <div class="sec-head text-center">
        <span class="eyebrow eyebrow--center">Services</span>
        <h2 class="h-section text-balance">
          Macam mana I boleh <span class="pink">bantu you.</span>
        </h2>
        <p class="lede lede--center text-balance">
          Dua cara untuk start financial planning journey you, pilih yang
          sesuai dengan keperluan you.
        </p>
      </div>

      <div class="svc-grid">
        <a href="/planning" class="svc">
          <div class="svc__head">
            <span class="badge badge--soft-pink">12-month engagement</span>
            <span class="svc__price-amt tabular">RM 3,500</span>
          </div>
          <h3 class="svc__title">
            Full Financial<br />Planning
          </h3>
          <p class="svc__desc">
            Engagement setahun yang cover semua aspek kewangan you secara
            menyeluruh, daripada A to Z. Semua strategi dan solusi akan
            di-customise ikut goals you, supaya kewangan you lebih tersusun,
            jelas, dan on track untuk jangka masa panjang.
          </p>
          <span class="svc__cta">
            Baca lagi
            <svg width="20" height="14" viewBox="0 0 20 14" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
              <line x1="0" y1="7" x2="18" y2="7" />
              <polyline points="12 1 18 7 12 13" />
            </svg>
          </span>
        </a>

        <a href="/fhc" class="svc svc--featured">
          <div class="svc__head">
            <span class="badge badge--on-ink">One-time review</span>
            <span class="svc__price-amt tabular">RM 350</span>
          </div>
          <h3 class="svc__title">
            Financial<br />Health Check
          </h3>
          <p class="svc__desc">
            One-time financial review untuk check keadaan kewangan you secara
            menyeluruh. You akan dapat insights yang jelas, objective, dan
            tanpa product push, supaya you tahu apa yang dah okay, apa yang
            perlu diperbaiki, dan macam mana nak betulkan.
          </p>
          <span class="svc__cta svc__cta--ink">
            Book now
            <svg width="20" height="14" viewBox="0 0 20 14" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
              <line x1="0" y1="7" x2="18" y2="7" />
              <polyline points="12 1 18 7 12 13" />
            </svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- =================== TESTIMONIALS =================== -->
  <!--
    TODO (REQUIRED before going live):
    These are placeholder testimonials. Financial-planning testimonials in
    Malaysia must be (a) genuine, (b) given with written consent, and
    (c) accurate. Replace each .tmn block below with a real client quote
    once consent is received. Do NOT publish this section as-is.
  -->
  <section class="section" id="testimonials">
    <div class="container-x">
      <div class="sec-head text-center">
        <span class="eyebrow eyebrow--center">From clients</span>
        <h2 class="h-section text-balance">
          Apa yang ladies kata <span class="pink">pasal kerja sama I.</span>
        </h2>
      </div>

      <div class="tmn-grid">
        <figure class="tmn glass-strong">
          <p class="tmn__quote">
            "First time rasa boleh tanya soalan kewangan tanpa rasa stupid.
            Iman explain everything dalam bahasa yang I faham, dan plan I
            sekarang ada step-by-step yang clear."
          </p>
          <figcaption class="tmn__cite">
            <span class="tmn__name">Aida</span>
            <span class="tmn__role">Marketing exec · KL</span>
          </figcaption>
        </figure>

        <figure class="tmn tmn--featured">
          <p class="tmn__quote">
            "I dah lama nak mula invest tapi takut buat salah. Lepas FHC,
            I finally tahu mana nak focus first. Worth every ringgit."
          </p>
          <figcaption class="tmn__cite">
            <span class="tmn__name">Sarah</span>
            <span class="tmn__role">Freelance designer · PJ</span>
          </figcaption>
        </figure>

        <figure class="tmn glass-strong">
          <p class="tmn__quote">
            "Yang I appreciate, dia tak push product. Dia recommend yang
            betul-betul sesuai untuk situation I — even kalau maknanya
            insurance I cukup dah, tak payah top up."
          </p>
          <figcaption class="tmn__cite">
            <span class="tmn__name">Nadia</span>
            <span class="tmn__role">Doctor · Shah Alam</span>
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- =================== ABOUT =================== -->
  <section class="section">
    <div class="container-tight">
      <div class="about-card glass-strong">
        <span class="eyebrow">About</span>
        <h2 class="h-section about__title text-balance">
          Kewangan you deserve <span class="pink">nasihat yang betul.</span>
        </h2>
        <div class="about__body">
          <p>
            I'm Iman Abdul Rahim, Licensed Financial Planner dengan pengalaman
            5 tahun tolong Malaysians macam you take control of duit sendiri.
          </p>
          <p>
            I licensed dengan Securities Commission Malaysia dan Bank Negara
            Malaysia, dan I pegang CFP® dan Islamic Financial Planner (IFP)
            certifications. I terikat dengan ethical codes dan fiduciary
            standards. Maknanya, I kena <em>always</em> act in your best interest.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- =================== FAQ =================== -->
  <section class="section">
    <div class="container-tight">
      <div class="sec-head">
        <span class="eyebrow">FAQ</span>
        <h2 class="h-section text-balance">
          Soalan <span class="pink">lazim.</span>
        </h2>
      </div>
      <div class="faq-card glass-strong">
        <Accordion items={faqs} />
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ---------- Hero ---------- */
  .hero {
    padding: clamp(3rem, 6vw, 6rem) 0 clamp(4rem, 7vw, 6rem);
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }
  .hero__glow-a {
    width: 720px;
    height: 720px;
    top: -200px;
    right: -200px;
    background: radial-gradient(circle, rgba(196, 69, 105, 0.08), transparent 65%);
    z-index: -1;
  }
  .hero__glow-b {
    width: 560px;
    height: 560px;
    bottom: -180px;
    left: -160px;
    background: radial-gradient(circle, rgba(249, 212, 220, 0.25), transparent 65%);
    z-index: -1;
  }
  .hero__inner {
    text-align: center;
    padding-top: clamp(2rem, 4vw, 3rem);
    padding-bottom: clamp(2.5rem, 5vw, 4rem);
    position: relative;
    z-index: 1;
  }
  .hero__eyebrow {
    display: inline-block;
    padding: 0.45rem 1rem;
    background: var(--glass-strong);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-primary);
    margin-bottom: 1.75rem;
    box-shadow: var(--shadow-glass);
  }
  .hero__title {
    margin: 0 auto;
    max-width: 18ch;
  }
  .hero__lede {
    margin: 1.75rem auto 0;
  }
  .hero__actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 2.5rem;
  }

  /* Trust strip */
  .trust {
    margin-top: clamp(3rem, 6vw, 5rem);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    padding: clamp(1.5rem, 3vw, 2rem) clamp(1.5rem, 3vw, 2.5rem);
    background: var(--glass-strong);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-glass);
  }
  .trust__item {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 0 1rem;
    position: relative;
    text-align: left;
  }
  .trust__item + .trust__item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 1px;
    height: 70%;
    background: var(--glass-border-pink);
  }
  .trust__label {
    font-size: 0.76rem;
    color: var(--color-muted-foreground);
    font-weight: 500;
    letter-spacing: -0.005em;
  }
  .trust__val {
    font-size: 1.18rem;
    color: var(--color-foreground);
    font-weight: 700;
    letter-spacing: -0.022em;
  }

  @media (max-width: 760px) {
    .trust {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      padding: 1.5rem;
    }
    .trust__item {
      padding: 0;
    }
    .trust__item + .trust__item::before {
      display: none;
    }
  }

  /* ---------- Section head ---------- */
  .sec-head {
    max-width: 760px;
    margin-bottom: clamp(3rem, 5vw, 4.5rem);
  }
  .sec-head.text-center {
    margin-left: auto;
    margin-right: auto;
  }
  .sec-head .h-section {
    margin-top: 1rem;
  }
  .sec-head .lede {
    margin-top: 1.25rem;
  }
  .sec-head.text-center .lede {
    margin-left: auto;
    margin-right: auto;
  }

  /* ---------- Services ---------- */
  .svc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1rem, 2vw, 1.5rem);
  }
  .svc {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: clamp(2rem, 3.5vw, 2.75rem);
    border-radius: var(--radius-3xl);
    background: var(--glass-strong);
    backdrop-filter: var(--glass-blur-strong);
    -webkit-backdrop-filter: var(--glass-blur-strong);
    border: 1px solid var(--glass-border);
    box-shadow: var(--shadow-glass);
    transition: box-shadow 0.25s ease, transform 0.25s ease;
    color: var(--color-foreground);
  }
  .svc:hover {
    box-shadow: var(--shadow-glass-lg);
    transform: translateY(-4px);
  }
  .svc--featured {
    background: var(--color-foreground);
    color: var(--color-paper);
    border-color: var(--color-foreground);
    box-shadow: var(--shadow-ink);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }
  .svc--featured:hover {
    box-shadow:
      0 1px 2px rgba(21, 5, 16, 0.2),
      0 28px 64px -14px rgba(21, 5, 16, 0.5);
  }
  .svc__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .svc__price-amt {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 2.2vw, 1.85rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: inherit;
  }
  .svc__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3vw, 2.6rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    color: inherit;
    line-height: 1;
    margin: 0;
  }
  .svc__desc {
    font-size: 0.98rem;
    line-height: 1.65;
    color: var(--color-ink-2);
    margin: 0;
    flex-grow: 1;
  }
  .svc--featured .svc__desc {
    color: rgba(255, 255, 255, 0.78);
  }
  .svc__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-primary);
    font-weight: 500;
    font-size: 0.96rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--glass-border-pink);
  }
  .svc--featured .svc__cta {
    color: var(--color-accent);
    border-top-color: rgba(255, 255, 255, 0.12);
  }
  .svc__cta svg {
    transition: transform 0.2s ease;
  }
  .svc:hover .svc__cta svg {
    transform: translateX(4px);
  }

  @media (max-width: 800px) {
    .svc-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ---------- Testimonials ---------- */
  .tmn-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: clamp(1rem, 1.8vw, 1.4rem);
  }
  .tmn {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    padding: clamp(1.75rem, 3vw, 2.25rem);
    border-radius: var(--radius-2xl);
    background: var(--glass-strong);
    backdrop-filter: var(--glass-blur-strong);
    -webkit-backdrop-filter: var(--glass-blur-strong);
    border: 1px solid var(--glass-border);
    box-shadow: var(--shadow-glass);
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }
  .tmn:hover {
    box-shadow: var(--shadow-glass-lg);
    transform: translateY(-4px);
  }
  .tmn--featured {
    background: var(--color-foreground);
    color: var(--color-paper);
    border-color: var(--color-foreground);
    box-shadow: var(--shadow-ink);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }
  .tmn__quote {
    margin: 0;
    font-size: clamp(1rem, 1.15vw, 1.08rem);
    line-height: 1.65;
    color: var(--color-ink-2);
    flex-grow: 1;
  }
  .tmn--featured .tmn__quote {
    color: rgba(255, 255, 255, 0.92);
  }
  .tmn__cite {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding-top: 1.1rem;
    border-top: 1px solid var(--glass-border-pink);
    font-style: normal;
  }
  .tmn--featured .tmn__cite {
    border-top-color: rgba(255, 255, 255, 0.12);
  }
  .tmn__name {
    font-weight: 600;
    font-size: 0.96rem;
    color: var(--color-foreground);
    letter-spacing: -0.01em;
  }
  .tmn--featured .tmn__name {
    color: var(--color-paper);
  }
  .tmn__role {
    font-size: 0.84rem;
    color: var(--color-muted-foreground);
  }
  .tmn--featured .tmn__role {
    color: rgba(255, 255, 255, 0.6);
  }
  @media (max-width: 900px) {
    .tmn-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ---------- About ---------- */
  .about-card {
    border-radius: var(--radius-3xl);
    padding: clamp(2.5rem, 5vw, 4rem);
  }
  .about__title {
    margin: 1rem 0 1.75rem;
    max-width: 18ch;
  }
  .about__body {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    font-size: clamp(1.06rem, 1.2vw, 1.18rem);
    color: var(--color-ink-2);
    line-height: 1.65;
    max-width: 62ch;
  }
  .about__body em {
    font-style: italic;
    color: var(--color-primary);
  }

  /* ---------- FAQ ---------- */
  .faq-card {
    border-radius: var(--radius-3xl);
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(2rem, 4vw, 3rem);
  }
</style>
