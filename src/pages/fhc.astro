---
import Layout from '../layouts/Layout.astro';

const bookHref = 'https://form.wealthvantage.com.my/iman-lead/';

const problems = [
  'Eh, I save cukup ke ni?',
  'Insurance I cukup ke tak?',
  'Nak start invest tapi tak tahu dari mana.',
  'Betul ke keputusan kewangan yang I buat?',
];

const audience = [
  {
    title: 'Fresh graduates',
    desc: 'Baru je start kerja, baru ada gaji, excited tapi confused nak buat apa dengan duit. Kita start dari sini.',
  },
  {
    title: 'Women yang nak clarity',
    desc: 'Women yang nak faham betul-betul keadaan kewangan sendiri dan take control of duit sendiri dengan yakin.',
  },
  {
    title: 'Yang nak tahu where they stand',
    desc: 'Tak kisah lah you baru nak start atau dah lama kerja, kalau you nak tahu keadaan kewangan sebenar, start di sini.',
  },
];

const deliverables = [
  {
    title: 'Dua kali sesi',
    desc: 'Sesi pertama adalah untuk kumpul dan faham data kewangan you, manakala sesi kedua adalah untuk pembentangan report.',
  },
  {
    title: 'Comprehensive PDF report',
    desc: 'Analysis menyeluruh pasal financial health you, documented dalam satu report yang jelas, senang faham, boleh refer balik bila-bila.',
  },
];

const outcomes = [
  {
    title: 'Buat keputusan kewangan dengan yakin',
    desc: 'Takde lagi rasa ragu-ragu. Setiap keputusan backed by data dan pemahaman yang betul.',
  },
  {
    title: 'Tahu exactly duit you pergi mana',
    desc: 'Full visibility on cash flow, savings, dan spending patterns you. Tak perlu teka-teki lagi.',
  },
  {
    title: 'Hala tuju yang jelas untuk masa depan',
    desc: 'Roadmap yang specific untuk you, bukan tips generic dari internet yang everyone boleh Google.',
  },
];
---

<Layout title="Financial Health Check · RM350 | Iman Abdul Rahim">
  <!-- =================== HERO =================== -->
  <section class="hero">
    <div class="hero__grain" aria-hidden="true"></div>
    <div class="container hero__inner">
      <span class="eyebrow">One-time Review · RM350</span>
      <h1 class="h-display">
        Financial<br /><em>Health Check.</em>
      </h1>
      <p class="lede hero__lede">
        Nak tahu betul-betul where you stand dari segi kewangan? Lepas ni you
        boleh buat keputusan dengan yakin, takde rasa was-was dah.
      </p>
    </div>
  </section>

  <!-- =================== PROBLEMS =================== -->
  <section class="section section--paper">
    <div class="container container--tight">
      <div class="section__intro section__intro--center">
        <span class="eyebrow eyebrow--center">The questions</span>
        <h2 class="h-section">
          Pernah tak terfikir <em>soalan ni?</em>
        </h2>
        <p class="lede lede--center">
          Trust me, you're not alone. Ramai je orang tanya benda yang sama.
        </p>
      </div>

      <div class="quotes">
        {
          problems.map((q) => (
            <figure class="quote">
              <span class="quote__mark" aria-hidden="true">&ldquo;</span>
              <p>{q}</p>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <!-- =================== WHY =================== -->
  <section class="section section--cream-deep">
    <div class="container container--tight why">
      <span class="eyebrow">Why it matters</span>
      <h2 class="h-section why__title">
        Masalahnya bukan takde duit,<br />
        <em>tapi tak faham keadaan kewangan sendiri.</em>
      </h2>
      <div class="why__body">
        <p>
          Ramai orang income okay je, tapi still rasa lost sebab tak pernah
          ambil masa untuk betul-betul faham financial picture sendiri.
          Relatable tak?
        </p>
        <p>
          Tanpa clarity, you buat keputusan based on agak-agak, bukan facts.
          That's why the first step is always a <strong>Financial Health Check</strong>.
        </p>
        <p>
          Once you dah tahu where you stand, baru lah you boleh plan dengan
          confident.
        </p>
      </div>
    </div>
  </section>

  <!-- =================== FOR WHO =================== -->
  <section class="section section--paper">
    <div class="container">
      <div class="section__intro section__intro--center">
        <span class="eyebrow eyebrow--center">Who it's for</span>
        <h2 class="h-section">
          Ni sesuai untuk <em>siapa?</em>
        </h2>
      </div>

      <div class="audience">
        {
          audience.map((a, i) => (
            <article class="aud">
              <span class="aud__num">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="aud__title">{a.title}</h3>
              <p class="aud__desc">{a.desc}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- =================== DELIVERABLES =================== -->
  <section class="section">
    <div class="container">
      <div class="section__intro">
        <span class="eyebrow">What you get</span>
        <h2 class="h-section">
          Apa yang you akan <em>dapat.</em>
        </h2>
      </div>

      <div class="deliverables">
        {
          deliverables.map((d, i) => (
            <article class="deliv">
              <span class="deliv__num">{String(i + 1).padStart(2, '0')}</span>
              <div>
                <h3 class="deliv__title">{d.title}</h3>
                <p class="deliv__desc">{d.desc}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- =================== SAMPLE REPORT =================== -->
  <section class="section section--paper">
    <div class="container container--tight">
      <div class="section__intro section__intro--center">
        <span class="eyebrow eyebrow--center">Sample report</span>
        <h2 class="h-section">
          Contoh report yang <em>you akan dapat.</em>
        </h2>
        <p class="lede lede--center">
          Ni lah preview actual report yang akan you terima, lengkap
          dengan Wealth Vantage Score&trade; yang scientific.
        </p>
      </div>

      <figure class="sample">
        <img
          src="/wealth-vantage-score.jpg"
          alt="Contoh Wealth Vantage Score report: gauge rated from Bad to Best"
          loading="lazy"
          width="1200"
          height="700"
        />
        <figcaption>
          Example&nbsp;&middot;&nbsp;Wealth Vantage Score&trade; rated 316/1000
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- =================== OUTCOMES =================== -->
  <section class="section section--cream-deep">
    <div class="container container--tight">
      <div class="section__intro">
        <span class="eyebrow">The outcome</span>
        <h2 class="h-section">
          Bila you dah tahu keadaan kewangan you<em>…</em>
        </h2>
      </div>

      <ul class="outcomes">
        {
          outcomes.map((o) => (
            <li class="outcome">
              <svg
                class="outcome__tick"
                aria-hidden="true"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <polyline points="20 6 9 17 4 12" />
              </svg>
              <div>
                <h3>{o.title}</h3>
                <p>{o.desc}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- =================== PRICING =================== -->
  <section class="section section--ink pricing">
    <div class="container container--narrow text-center">
      <span class="eyebrow eyebrow--center eyebrow--on-dark">Pricing</span>

      <div class="pricing__card">
        <span class="pricing__tag">Financial Health Check</span>
        <div class="pricing__amt">RM 350</div>
        <span class="pricing__note">Bayar sekali je + 8% SST</span>

        <ul class="pricing__features">
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Dua kali sesi
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Comprehensive PDF report
          </li>
        </ul>

        <a href={bookHref} target="_blank" rel="noopener" class="btn btn--primary btn--lg pricing__cta">
          Book your slot
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* =================== HERO =================== */
  .hero {
    position: relative;
    padding: clamp(8rem, 14vw, 12rem) 0 clamp(4rem, 7vw, 6rem);
    background: var(--cream);
    overflow: hidden;
    isolation: isolate;
  }
  .hero__grain {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 75% 15%, var(--rose-tint) 0%, transparent 55%),
      radial-gradient(circle at 10% 90%, var(--shell) 0%, transparent 45%);
    opacity: 0.65;
    z-index: -1;
  }
  .hero__inner {
    max-width: 820px;
  }
  .hero__lede {
    margin: 1.5rem 0 2.25rem;
  }
  /* =================== QUOTES =================== */
  .quotes {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  .quote {
    position: relative;
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    padding: 3.25rem 1.75rem 1.75rem;
    margin: 0;
  }
  .quote__mark {
    font-family: var(--font-serif);
    position: absolute;
    top: 0.75rem;
    left: 1.4rem;
    font-size: 2.2rem;
    line-height: 1;
    color: var(--rose);
    opacity: 0.55;
    pointer-events: none;
  }
  .quote p {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--ink);
    line-height: 1.5;
    letter-spacing: -0.01em;
  }
  @media (max-width: 640px) {
    .quotes {
      grid-template-columns: 1fr;
    }
  }

  /* =================== WHY =================== */
  .why {
    max-width: 720px;
  }
  .why__title {
    margin-top: 1rem;
  }
  .why__body {
    margin-top: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .why__body p {
    font-size: 1rem;
    color: var(--text-2);
    line-height: 1.8;
    max-width: 60ch;
  }
  .why__body strong {
    color: var(--ink);
    font-weight: 600;
  }

  /* =================== AUDIENCE =================== */
  .audience {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    overflow: hidden;
  }
  .aud {
    background: var(--cream);
    padding: clamp(1.75rem, 3vw, 2.5rem);
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .aud__num {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--rose-deep);
    letter-spacing: 0.05em;
  }
  .aud__title {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .aud__desc {
    font-size: 0.93rem;
    color: var(--text-2);
    line-height: 1.7;
  }
  @media (max-width: 860px) {
    .audience {
      grid-template-columns: 1fr;
    }
  }

  /* =================== DELIVERABLES =================== */
  .deliverables {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .deliv {
    display: grid;
    grid-template-columns: 70px 1fr;
    gap: 1.5rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--hairline);
    align-items: start;
  }
  .deliv:last-child {
    border-bottom: 0;
  }
  .deliv__num {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 2rem;
    color: var(--rose-deep);
    font-weight: 400;
    line-height: 1;
  }
  .deliv__title {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 0.45rem;
    letter-spacing: -0.01em;
  }
  .deliv__desc {
    font-size: 0.96rem;
    color: var(--text-2);
    line-height: 1.75;
  }
  @media (max-width: 560px) {
    .deliv {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }

  /* =================== SAMPLE REPORT =================== */
  .sample {
    margin: 2.5rem auto 0;
    max-width: 760px;
  }
  .sample img {
    width: 100%;
    height: auto;
    aspect-ratio: 12 / 7;
    object-fit: contain;
    border-radius: var(--r-lg);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    background: var(--paper);
    padding: clamp(1rem, 3vw, 2rem);
  }
  .sample figcaption {
    margin-top: 1rem;
    font-size: 0.82rem;
    color: var(--text-2);
    text-align: center;
    letter-spacing: 0.02em;
  }

  /* =================== OUTCOMES =================== */
  .outcomes {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .outcome {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: var(--paper);
    border: 1px solid var(--border);
    border-radius: var(--r);
    align-items: start;
  }
  .outcome__tick {
    width: 32px;
    height: 32px;
    padding: 6px;
    background: var(--rose-tint);
    color: var(--rose-deep);
    border-radius: 50%;
    flex-shrink: 0;
  }
  .outcome h3 {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 0.3rem;
    letter-spacing: -0.01em;
  }
  .outcome p {
    font-size: 0.92rem;
    color: var(--text-2);
    line-height: 1.65;
  }

  /* =================== PRICING =================== */
  .pricing__card {
    max-width: 440px;
    margin: 2.5rem auto 0;
    background: var(--cream);
    color: var(--ink);
    border-radius: var(--r-xl);
    padding: clamp(2rem, 4vw, 2.75rem);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .pricing__card::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--rose-deep), var(--gold));
  }
  .pricing__tag {
    display: inline-block;
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rose-deep);
    font-weight: 600;
    margin-bottom: 1rem;
  }
  .pricing__amt {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 5vw, 3.2rem);
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .pricing__note {
    display: block;
    font-size: 0.8rem;
    color: var(--text-2);
    margin: 0.6rem 0 1.5rem;
  }
  .pricing__features {
    list-style: none;
    padding: 1.25rem 0;
    margin: 0 0 1.5rem;
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    text-align: left;
  }
  .pricing__features li {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-size: 0.93rem;
    color: var(--text);
  }
  .pricing__features svg {
    color: var(--rose-deep);
    flex-shrink: 0;
  }
  .pricing__cta {
    width: 100%;
    justify-content: center;
  }
  .pricing__fineprint {
    font-size: 0.78rem;
    color: var(--text-2);
    font-style: italic;
    margin-top: 1.2rem;
  }

  .pricing .eyebrow--center {
    justify-content: center;
  }

  .pricing h2 {
    margin-bottom: 0.5rem;
  }
</style>
