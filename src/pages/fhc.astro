---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Financial Health Check — RM350 | Iman Abdul Rahim">

  <!-- Hero Section -->
  <section class="section hero">
    <div class="container">
      <div class="hero__badge">Financial Planning</div>
