---
import Layout from '../layouts/Layout.astro';

const bookHref = 'https://form.wealthvantage.com.my/iman-lead/';

const problems = [
  'Eh, I save cukup ke ni?',
  'Insurance I cukup ke tak?',
  'Nak start invest tapi tak tahu dari mana.',
  'Betul ke keputusan kewangan yang I buat?',
];

const audience = [
  { title: 'Fresh graduates', desc: 'Baru je start kerja, baru ada gaji, excited tapi confused nak buat apa dengan duit. Kita start dari sini.' },
  { title: 'Women yang nak clarity', desc: 'Women yang nak faham betul-betul keadaan kewangan sendiri dan take control of duit sendiri dengan yakin.' },
  { title: 'Yang nak tahu where they stand', desc: 'Tak kisah lah you baru nak start atau dah lama kerja, kalau you nak tahu keadaan kewangan sebenar, start di sini.' },
];

const deliverables = [
  { title: 'Dua kali sesi', desc: 'Sesi pertama adalah untuk kumpul dan faham data kewangan you, manakala sesi kedua adalah untuk pembentangan report.' },
  { title: 'Comprehensive PDF report', desc: 'Analysis menyeluruh pasal financial health you, documented dalam satu report yang jelas, senang faham, boleh refer balik bila-bila.' },
];

const outcomes = [
  { title: 'Buat keputusan kewangan dengan yakin', desc: 'Takde lagi rasa ragu-ragu. Setiap keputusan backed by data dan pemahaman yang betul.' },
  { title: 'Tahu exactly duit you pergi mana', desc: 'Full visibility on cash flow, savings, dan spending patterns you. Tak perlu teka-teki lagi.' },
  { title: 'Hala tuju yang jelas untuk masa depan', desc: 'Roadmap yang specific untuk you, bukan tips generic dari internet yang everyone boleh Google.' },
];
---

<Layout title="Financial Health Check · RM350 | Iman Abdul Rahim">
  <!-- HERO -->
  <section class="hero">

    <div class="container-x hero__inner">
      <span class="hero__eyebrow">One-time Review · RM 350</span>
      <h1 class="h-display hero__title text-balance">
        Financial<br /><span class="pink">Health Check.</span>
      </h1>
      <p class="lede lede--xl lede--center hero__lede text-balance">
        Nak tahu betul-betul where you stand dari segi kewangan? Lepas ni you
        boleh buat keputusan dengan yakin, takde rasa was-was dah.
      </p>
      <div class="hero__actions">
        <a href={bookHref} target="_blank" rel="noopener" class="btn btn--primary btn--lg">
          Book your slot
        </a>
        <a href="#sample" class="btn btn--glass btn--lg btn--arrow">See sample report</a>
      </div>
    </div>
  </section>

  <!-- PROBLEMS -->
  <section class="section">
    <div class="container-tight">
      <div class="sec-head text-center">
        <span class="eyebrow eyebrow--center">The questions</span>
        <h2 class="h-section text-balance">
          Pernah tak terfikir <span class="pink">soalan ni?</span>
        </h2>
        <p class="lede lede--center">
          Trust me, you're not alone. Ramai je orang tanya benda yang sama.
        </p>
      </div>

      <ul class="quotes">
        {problems.map((q) => (
          <li class="quote">
            <span class="quote__mark" aria-hidden="true">&ldquo;</span>
            <p>{q}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- WHY -->
  <section class="section">
    <div class="container-tight">
      <div class="why-card glass-pink">
        <span class="eyebrow">Why it matters</span>
        <h2 class="h-section why__title text-balance">
          Masalahnya bukan takde duit, <span class="pink">tapi tak faham keadaan kewangan sendiri.</span>
        </h2>
        <div class="why__body">
          <p>
            Ramai orang income okay je, tapi still rasa lost sebab tak pernah
            ambil masa untuk betul-betul faham financial picture sendiri.
            Relatable tak?
          </p>
          <p>
            Tanpa clarity, you buat keputusan based on agak-agak, bukan facts.
            That's why the first step is always a <strong>Financial Health Check</strong>.
          </p>
          <p>
            Once you dah tahu where you stand, baru lah you boleh plan dengan
            confident.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- AUDIENCE -->
  <section class="section">
    <div class="container-x">
      <div class="sec-head text-center">
        <span class="eyebrow eyebrow--center">Who it's for</span>
        <h2 class="h-section text-balance">
          Ni sesuai untuk <span class="pink">siapa?</span>
        </h2>
      </div>

      <ul class="aud-grid">
        {audience.map((a, i) => (
          <li class="aud-card">
            <span class="aud-card__num">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="aud-card__title">{a.title}</h3>
            <p class="aud-card__desc">{a.desc}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- DELIVERABLES -->
  <section class="section">
    <div class="container-x">
      <div class="sec-head">
        <span class="eyebrow">What you get</span>
        <h2 class="h-section text-balance">
          Apa yang you akan <span class="pink">dapat.</span>
        </h2>
      </div>

      <ul class="deliv-grid">
        {deliverables.map((d, i) => (
          <li class="deliv">
            <span class="deliv__num">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <h3 class="deliv__title">{d.title}</h3>
              <p class="deliv__desc">{d.desc}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- SAMPLE -->
  <section class="section" id="sample">
    <div class="container-tight">
      <div class="sec-head text-center">
        <span class="eyebrow eyebrow--center">Sample report</span>
        <h2 class="h-section text-balance">
          Contoh report yang <span class="pink">you akan dapat.</span>
        </h2>
        <p class="lede lede--center">
          Ni lah preview actual report yang akan you terima, lengkap dengan
          Wealth Vantage Score&trade; yang scientific.
        </p>
      </div>

      <figure class="sample wv-card glass-strong">
        <svg
          viewBox="0 0 400 300"
          class="wv-gauge"
          role="img"
          aria-labelledby="wv-title wv-desc"
        >
          <title id="wv-title">Wealth Vantage Score gauge</title>
          <desc id="wv-desc">
            Example score of 316 out of 1,000 — needle points to the Poor band.
          </desc>

          <!-- Spectrum gradient · smooth transitions between the 5 original bands -->
          <defs>
            <linearGradient
              id="wvSpectrum"
              gradientUnits="userSpaceOnUse"
              x1="50"
              y1="0"
              x2="350"
              y2="0"
            >
              <stop offset="0%" stop-color="#E1252F" />
              <stop offset="14%" stop-color="#E84A1F" />
              <stop offset="25%" stop-color="#F1B70F" />
              <stop offset="38%" stop-color="#B8B72A" />
              <stop offset="50%" stop-color="#3CB44A" />
              <stop offset="62%" stop-color="#46C293" />
              <stop offset="75%" stop-color="#4ECDE0" />
              <stop offset="88%" stop-color="#3A8DB6" />
              <stop offset="100%" stop-color="#1B4E8D" />
            </linearGradient>
          </defs>

          <!-- Single arc rendered with the spectrum gradient -->
          <path
            d="M 50 200 A 150 150 0 0 1 350 200"
            stroke="url(#wvSpectrum)"
            stroke-width="34"
            stroke-linecap="round"
            fill="none"
          />

          <!-- Needle from pivot (200, 200) to score position (118, 74.4) for 316/1000 -->
          <line
            x1="200"
            y1="200"
            x2="118"
            y2="74.4"
            stroke="#1a1216"
            stroke-width="2.5"
            stroke-linecap="round"
          />
          <circle cx="200" cy="200" r="7" fill="#1a1216" />

          <!-- Score number in navy · matches the original -->
          <text x="200" y="252" text-anchor="middle" class="wv-num">316</text>

          <!-- Band labels (uppercase, original wording: BAD POOR FAIR GOOD BEST) -->
          <g class="wv-band-labels">
            <text x="57.4" y="282" text-anchor="middle">BAD</text>
            <text x="111.8" y="282" text-anchor="middle">POOR</text>
            <text x="200" y="282" text-anchor="middle">FAIR</text>
            <text x="288.2" y="282" text-anchor="middle">GOOD</text>
            <text x="342.6" y="282" text-anchor="middle">BEST</text>
          </g>
        </svg>

        <figcaption>
          Example &middot; Wealth Vantage Score&trade; rated 316/1000
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- OUTCOMES -->
  <section class="section">
    <div class="container-tight">
      <div class="sec-head">
        <span class="eyebrow">The outcome</span>
        <h2 class="h-section text-balance">
          Bila you dah tahu keadaan kewangan you<span class="pink">…</span>
        </h2>
      </div>

      <ul class="outcomes">
        {outcomes.map((o) => (
          <li class="outcome glass-strong">
            <span class="outcome__tick" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12" />
              </svg>
            </span>
            <div>
              <h3>{o.title}</h3>
              <p>{o.desc}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- PRICING -->
  <section class="section">
    <div class="container-narrow">
      <div class="pricing">
        <span class="badge badge--pink">Financial Health Check</span>
        <div class="pricing__amt">
          <span class="pricing__currency">RM</span><span class="pricing__num tabular">350</span>
        </div>
        <p class="pricing__note">Bayar sekali je + 8% SST</p>

        <ul class="pricing__features">
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Dua kali sesi
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Comprehensive PDF report
          </li>
        </ul>

        <a href={bookHref} target="_blank" rel="noopener" class="btn btn--primary btn--lg btn--full btn--arrow">
          Book your slot
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding: clamp(3rem, 6vw, 6rem) 0 clamp(4rem, 7vw, 7rem);
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }
  .hero__glow-a {
    width: 640px; height: 640px; top: -180px; right: -160px;
    background: radial-gradient(circle, rgba(196, 69, 105, 0.07), transparent 65%);
    z-index: -1;
  }
  .hero__glow-b {
    width: 520px; height: 520px; bottom: -160px; left: -160px;
    background: radial-gradient(circle, rgba(249, 212, 220, 0.22), transparent 65%);
    z-index: -1;
  }
  .hero__inner {
    text-align: center;
    position: relative; z-index: 1;
  }
  .hero__eyebrow {
    display: inline-block;
    padding: 0.45rem 1rem;
    background: var(--glass-strong);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-primary);
    margin-bottom: 1.75rem;
    box-shadow: var(--shadow-glass);
  }
  .hero__title { margin: 0 auto; }
  .hero__lede { margin: 1.75rem auto 0; }
  .hero__actions {
    display: flex; gap: 0.75rem; flex-wrap: wrap;
    justify-content: center;
    margin-top: 2.5rem;
  }

  .sec-head {
    max-width: 760px;
    margin-bottom: clamp(3rem, 5vw, 4.5rem);
  }
  .sec-head.text-center { margin-left: auto; margin-right: auto; }
  .sec-head .h-section { margin-top: 1rem; }
  .sec-head .lede { margin-top: 1.25rem; }
  .sec-head.text-center .lede { margin-left: auto; margin-right: auto; }

  /* Quotes */
  .quotes {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  .quote {
    background: var(--glass-strong);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-xl);
    padding: 2.5rem 1.75rem 1.75rem;
    position: relative;
    box-shadow: var(--shadow-glass);
  }
  .quote__mark {
    font-family: var(--font-display);
    position: absolute;
    top: 0.4rem;
    left: 1.4rem;
    font-size: 4rem;
    line-height: 1;
    color: var(--color-primary);
    font-weight: 700;
  }
  .quote p {
    font-size: 1.18rem;
    color: var(--color-foreground);
    line-height: 1.4;
    font-weight: 500;
    letter-spacing: -0.018em;
    margin: 0;
  }
  @media (max-width: 640px) {
    .quotes { grid-template-columns: 1fr; }
  }

  /* Why */
  .why-card {
    border-radius: var(--radius-3xl);
    padding: clamp(2rem, 4.5vw, 3.5rem);
  }
  .why__title { margin: 1rem 0 0; }
  .why__body {
    margin-top: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .why__body p {
    font-size: 1.05rem;
    color: var(--color-ink-2);
    line-height: 1.7;
    margin: 0;
    max-width: 62ch;
  }
  .why__body strong {
    color: var(--color-foreground);
    font-weight: 600;
  }

  /* Audience */
  .aud-grid {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .aud-card {
    background: var(--glass-strong);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-2xl);
    padding: clamp(1.75rem, 3vw, 2.25rem);
    box-shadow: var(--shadow-glass);
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .aud-card__num {
    display: inline-block;
    width: 36px; height: 36px;
    border-radius: 50%;
    background: var(--color-primary);
    color: var(--color-paper);
    font-size: 0.85rem;
    font-weight: 600;
    display: flex; align-items: center; justify-content: center;
    font-variant-numeric: tabular-nums;
  }
  .aud-card__title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--color-foreground);
    letter-spacing: -0.025em;
    line-height: 1.15;
    margin: 0;
  }
  .aud-card__desc {
    font-size: 0.96rem;
    color: var(--color-ink-2);
    line-height: 1.65;
    margin: 0;
  }
  @media (max-width: 860px) {
    .aud-grid { grid-template-columns: 1fr; }
  }

  /* Deliverables */
  .deliv-grid {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  .deliv {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 1.25rem;
    padding: clamp(1.75rem, 3vw, 2.25rem);
    background: var(--glass-strong);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-glass);
    align-items: start;
  }
  .deliv__num {
    width: 44px; height: 44px;
    background: var(--color-blush);
    color: var(--color-primary);
    border-radius: 12px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.05rem;
    display: flex; align-items: center; justify-content: center;
    font-variant-numeric: tabular-nums;
  }
  .deliv__title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-foreground);
    letter-spacing: -0.025em;
    margin: 0 0 0.4rem;
  }
  .deliv__desc {
    font-size: 0.97rem;
    color: var(--color-ink-2);
    line-height: 1.7;
    margin: 0;
  }
  @media (max-width: 720px) {
    .deliv-grid { grid-template-columns: 1fr; }
  }

  /* Sample */
  /* ---------- Wealth Vantage Score gauge (original colour wheel) ---------- */
  .wv-card {
    margin: 0 auto;
    max-width: 640px;
    padding: clamp(1.75rem, 3.5vw, 2.75rem);
    border-radius: var(--radius-3xl);
  }
  .wv-gauge {
    display: block;
    width: 100%;
    height: auto;
    max-width: 540px;
    margin: 0 auto;
  }
  .wv-num {
    font-family: var(--font-sans);
    font-variant-numeric: tabular-nums;
    font-size: 38px;
    font-weight: 600;
    fill: #1B4E8D; /* navy — matches original WEALTH VANTAGE SCORE™ ink */
    letter-spacing: -0.02em;
  }
  .wv-band-labels text {
    font-family: var(--font-sans);
    font-size: 11.5px;
    font-weight: 600;
    fill: var(--color-ink-2);
    letter-spacing: 0.05em;
  }
  .wv-card figcaption {
    margin-top: 1.5rem;
    font-size: 0.86rem;
    color: var(--color-muted-foreground);
    text-align: center;
  }

  /* Needle is static — matches the original report's resting state */

  /* Outcomes */
  .outcomes {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column;
    gap: 1rem;
  }
  .outcome {
    display: grid;
    grid-template-columns: 44px 1fr;
    gap: 1.25rem;
    padding: 1.4rem 1.75rem;
    border-radius: var(--radius-xl);
    align-items: start;
  }
  .outcome__tick {
    width: 36px; height: 36px;
    display: grid; place-items: center;
    background: var(--color-primary);
    color: var(--color-paper);
    border-radius: 50%;
    margin-top: 2px;
  }
  .outcome h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin: 0 0 0.3rem;
    letter-spacing: -0.02em;
  }
  .outcome p {
    font-size: 0.96rem;
    color: var(--color-ink-2);
    line-height: 1.65;
    margin: 0;
  }

  /* Pricing */
  .pricing {
    max-width: 480px;
    margin: 0 auto;
    background: var(--glass-strong);
    backdrop-filter: var(--glass-blur-strong);
    -webkit-backdrop-filter: var(--glass-blur-strong);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-3xl);
    padding: clamp(2.25rem, 4.5vw, 3rem);
    text-align: center;
    box-shadow: var(--shadow-glass-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.1rem;
  }
  .pricing__amt {
    display: inline-flex;
    align-items: baseline;
    gap: 0.3rem;
    color: var(--color-foreground);
    font-family: var(--font-display);
    line-height: 1;
  }
  .pricing__currency {
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--color-muted-foreground);
  }
  .pricing__num {
    font-size: clamp(3.5rem, 7vw, 4.5rem);
    font-weight: 700;
    letter-spacing: -0.045em;
  }
  .pricing__note {
    font-size: 0.9rem;
    color: var(--color-muted-foreground);
    margin: 0;
  }
  .pricing__features {
    list-style: none; padding: 1.5rem 0; margin: 0;
    width: 100%;
    border-top: 1px solid var(--glass-border-pink);
    border-bottom: 1px solid var(--glass-border-pink);
    display: flex; flex-direction: column;
    gap: 0.85rem;
    text-align: left;
  }
  .pricing__features li {
    display: flex; align-items: center;
    gap: 0.75rem;
    font-size: 0.97rem;
    color: var(--color-foreground);
    font-weight: 500;
  }
  .pricing__features svg {
    color: var(--color-primary);
    flex-shrink: 0;
  }
</style>
