<style>
  /* ===== Hero ===== */
  .hero {
    text-align: center;
    padding: 6rem 1.5rem 4rem;
    background: linear-gradient(135deg, var(--pink-soft) 0%, var(--cream) 50%, var(--blush) 100%);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle at 30% 50%, rgba(255, 255, 255, 0.3) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero__badge {
    display: inline-block;
    background: var(--rose-gold-light);
    color: var(--rose-gold-dark);
    padding: 0.4rem 1.2rem;
    border-radius: 50px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .hero__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    color: var(--text);
    margin-bottom: 1rem;
    line-height: 1.2;
    position: relative;
  }

  .hero__subtitle {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }

  .hero__price {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    margin-bottom: 2rem;
  }

  .hero__price-amount {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--rose-gold-dark);
  }

  .hero__price-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .hero__cta {
    font-size: 1.1rem;
    padding: 1rem 2.5rem;
  }

  /* ===== Section Base ===== */
  .section {
    padding: 5rem 1.5rem;
  }

  .section--cream {
    background-color: var(--cream);
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .section__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    color: var(--text);
    text-align: center;
    margin-bottom: 1rem;
  }

  .section__subtitle {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.05rem;
    color: var(--text-secondary);
    text-align: center;
    margin-bottom: 3rem;
  }

  /* ===== Cards ===== */
  .card {
    background: var(--white);
    border: 1px solid var(--border-light);
    border-radius: 16px;
    padding: 2rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.06);
  }

  /* ===== Problems ===== */
  .problems__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .problems__card {
    text-align: center;
    padding: 2rem 1.5rem;
  }

  .problems__icon {
    width: 48px;
    height: 48px;
    background: var(--rose-gold-light);
    color: var(--rose-gold-dark);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 auto 1rem;
  }

  .problems__card p {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    color: var(--text-secondary);
    font-style: italic;
    line-height: 1.5;
  }

  /* ===== Audience ===== */
  .audience__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .audience__card {
    text-align: center;
    padding: 2.5rem 1.5rem;
  }

  .audience__emoji {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .audience__card h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.15rem;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .audience__card p {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* ===== Why ===== */
  .why__content {
    max-width: 700px;
    margin: 2rem auto 0;
    text-align: center;
  }

  .why__highlight {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.2rem, 3vw, 1.5rem);
    color: var(--rose-gold-dark);
    font-weight: 600;
    line-height: 1.5;
    margin-bottom: 1.5rem;
    padding: 1.5rem;
    background: var(--white);
    border-left: 4px solid var(--rose-gold);
    border-radius: 0 12px 12px 0;
  }

  .why__text p {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  /* ===== What You Get ===== */
  .whatyouget__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .whatyouget__card {
    text-align: center;
    padding: 2.5rem 1.5rem;
  }

  .whatyouget__icon {
    width: 64px;
    height: 64px;
    background: linear-gradient(135deg, var(--rose-gold-light), var(--pink-soft));
    color: var(--rose-gold-dark);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.25rem;
  }

  .whatyouget__card h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.15rem;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .whatyouget__card p {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* ===== Benefits ===== */
  .benefits__grid {
    max-width: 700px;
    margin: 2.5rem auto 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .benefits__item {
