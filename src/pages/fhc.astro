---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import wealthVantageScore from '../assets/wealth-vantage-score.jpg';

const bookHref = 'https://form.wealthvantage.com.my/iman-lead/';

const problems = [
  'Eh, I save cukup ke ni?',
  'Insurance I cukup ke tak?',
  'Nak start invest tapi tak tahu dari mana.',
  'Betul ke keputusan kewangan yang I buat?',
];

const audience = [
  {
    title: 'Fresh graduates',
    desc: 'Baru je start kerja, baru ada gaji, excited tapi confused nak buat apa dengan duit. Kita start dari sini.',
  },
  {
    title: 'Women yang nak clarity',
    desc: 'Women yang nak faham betul-betul keadaan kewangan sendiri dan take control of duit sendiri dengan yakin.',
  },
  {
    title: 'Yang nak tahu where they stand',
    desc: 'Tak kisah lah you baru nak start atau dah lama kerja, kalau you nak tahu keadaan kewangan sebenar, start di sini.',
  },
];

const deliverables = [
  {
    title: 'Dua kali sesi',
    desc: 'Sesi pertama adalah untuk kumpul dan faham data kewangan you, manakala sesi kedua adalah untuk pembentangan report.',
  },
  {
    title: 'Comprehensive PDF report',
    desc: 'Analysis menyeluruh pasal financial health you, documented dalam satu report yang jelas, senang faham, boleh refer balik bila-bila.',
  },
];

const outcomes = [
  {
    title: 'Buat keputusan kewangan dengan yakin',
    desc: 'Takde lagi rasa ragu-ragu. Setiap keputusan backed by data dan pemahaman yang betul.',
  },
  {
    title: 'Tahu exactly duit you pergi mana',
    desc: 'Full visibility on cash flow, savings, dan spending patterns you. Tak perlu teka-teki lagi.',
  },
  {
    title: 'Hala tuju yang jelas untuk masa depan',
    desc: 'Roadmap yang specific untuk you, bukan tips generic dari internet yang everyone boleh Google.',
  },
];
---

<Layout title="Financial Health Check · RM350 | Iman Abdul Rahim">
  <!-- =================== HERO =================== -->
  <section class="hero">
    <div class="glow glow--a" aria-hidden="true"></div>
    <div class="glow glow--b" aria-hidden="true"></div>

    <div class="container-x hero__inner">
      <span class="eyebrow">One-time Review · RM350</span>
      <h1 class="h-display">
        Financial<br /><em>Health Check.</em>
      </h1>
      <p class="lede hero__lede">
        Nak tahu betul-betul where you stand dari segi kewangan? Lepas ni you
        boleh buat keputusan dengan yakin, takde rasa was-was dah.
      </p>
    </div>
  </section>

  <!-- =================== PROBLEMS =================== -->
  <section class="section">
    <div class="container-tight">
      <div class="section__intro section__intro--center">
        <span class="eyebrow eyebrow--center">The questions</span>
        <h2 class="h-section">
          Pernah tak terfikir <em>soalan ni?</em>
        </h2>
        <p class="lede lede--center">
          Trust me, you're not alone. Ramai je orang tanya benda yang sama.
        </p>
      </div>

      <div class="quotes">
        {
          problems.map((q) => (
            <figure class="quote glass">
              <span class="quote__mark" aria-hidden="true">&ldquo;</span>
              <p>{q}</p>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <!-- =================== WHY =================== -->
  <section class="section">
    <div class="container-tight">
      <div class="why-card glass-pink">
        <span class="eyebrow">Why it matters</span>
        <h2 class="h-section why__title">
          Masalahnya bukan takde duit,<br />
          <em>tapi tak faham keadaan kewangan sendiri.</em>
        </h2>
        <div class="why__body">
          <p>
            Ramai orang income okay je, tapi still rasa lost sebab tak pernah
            ambil masa untuk betul-betul faham financial picture sendiri.
            Relatable tak?
          </p>
          <p>
            Tanpa clarity, you buat keputusan based on agak-agak, bukan facts.
            That's why the first step is always a <strong>Financial Health Check</strong>.
          </p>
          <p>
            Once you dah tahu where you stand, baru lah you boleh plan dengan
            confident.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- =================== FOR WHO =================== -->
  <section class="section">
    <div class="container-x">
      <div class="section__intro section__intro--center">
        <span class="eyebrow eyebrow--center">Who it's for</span>
        <h2 class="h-section">
          Ni sesuai untuk <em>siapa?</em>
        </h2>
      </div>

      <div class="audience">
        {
          audience.map((a, i) => (
            <article class="aud glass">
              <span class="aud__num">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="aud__title">{a.title}</h3>
              <p class="aud__desc">{a.desc}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- =================== DELIVERABLES =================== -->
  <section class="section">
    <div class="container-x">
      <div class="section__intro">
        <span class="eyebrow">What you get</span>
        <h2 class="h-section">
          Apa yang you akan <em>dapat.</em>
        </h2>
      </div>

      <div class="deliverables">
        {
          deliverables.map((d, i) => (
            <article class="deliv glass">
              <span class="deliv__num">{String(i + 1).padStart(2, '0')}</span>
              <div>
                <h3 class="deliv__title">{d.title}</h3>
                <p class="deliv__desc">{d.desc}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- =================== SAMPLE REPORT =================== -->
  <section class="section">
    <div class="container-tight">
      <div class="section__intro section__intro--center">
        <span class="eyebrow eyebrow--center">Sample report</span>
        <h2 class="h-section">
          Contoh report yang <em>you akan dapat.</em>
        </h2>
        <p class="lede lede--center">
          Ni lah preview actual report yang akan you terima, lengkap
          dengan Wealth Vantage Score&trade; yang scientific.
        </p>
      </div>

      <figure class="sample glass">
        <Image
          src={wealthVantageScore}
          alt="Contoh Wealth Vantage Score report: gauge rated from Bad to Best"
          loading="lazy"
          widths={[480, 800, 1200]}
          sizes="(max-width: 800px) 100vw, 760px"
          format="avif"
        />
        <figcaption>
          Example&nbsp;&middot;&nbsp;Wealth Vantage Score&trade; rated 316/1000
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- =================== OUTCOMES =================== -->
  <section class="section">
    <div class="container-tight">
      <div class="section__intro">
        <span class="eyebrow">The outcome</span>
        <h2 class="h-section">
          Bila you dah tahu keadaan kewangan you<em>…</em>
        </h2>
      </div>

      <ul class="outcomes">
        {
          outcomes.map((o) => (
            <li class="outcome glass">
              <span class="outcome__tick">
                <svg
                  aria-hidden="true"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polyline points="20 6 9 17 4 12" />
                </svg>
              </span>
              <div>
                <h3>{o.title}</h3>
                <p>{o.desc}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- =================== PRICING =================== -->
  <section class="section pricing-section">
    <div class="container-narrow text-center">
      <span class="eyebrow eyebrow--center">Pricing</span>

      <div class="pricing__card glass-pink">
        <span class="pricing__tag">Financial Health Check</span>
        <div class="pricing__amt">RM 350</div>
        <span class="pricing__note">Bayar sekali je + 8% SST</span>

        <ul class="pricing__features">
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Dua kali sesi
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Comprehensive PDF report
          </li>
        </ul>

        <a href={bookHref} target="_blank" rel="noopener" class="btn btn--rose btn--lg pricing__cta">
          Book your slot
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* =================== HERO =================== */
  .hero {
    position: relative;
    padding: clamp(8rem, 14vw, 12rem) 0 clamp(4rem, 7vw, 6rem);
    overflow: hidden;
    isolation: isolate;
  }
  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    pointer-events: none;
    z-index: -1;
  }
  .glow--a {
    width: 480px;
    height: 480px;
    top: -120px;
    right: -100px;
    background: radial-gradient(circle, rgba(236, 108, 135, 0.16), transparent 70%);
  }
  .glow--b {
    width: 420px;
    height: 420px;
    bottom: -100px;
    left: -120px;
    background: radial-gradient(circle, rgba(244, 163, 179, 0.14), transparent 70%);
  }
  .hero__inner {
    max-width: 820px;
  }
  .hero__lede {
    margin: 1.5rem 0 0;
  }

  /* =================== QUOTES =================== */
  .quotes {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  .quote {
    position: relative;
    border-radius: 24px;
    padding: 3.25rem 1.75rem 1.75rem;
    margin: 0;
  }
  .quote__mark {
    font-family: var(--font-serif);
    position: absolute;
    top: 0.85rem;
    left: 1.5rem;
    font-size: 2.6rem;
    line-height: 1;
    color: var(--color-deep);
    opacity: 0.35;
    pointer-events: none;
  }
  .quote p {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.15rem;
    color: var(--color-ink);
    line-height: 1.5;
    letter-spacing: -0.015em;
  }
  @media (max-width: 640px) {
    .quotes { grid-template-columns: 1fr; }
  }

  /* =================== WHY =================== */
  .why-card {
    border-radius: 32px;
    padding: clamp(2rem, 4.5vw, 3.5rem);
    max-width: 760px;
    margin: 0 auto;
  }
  .why__title { margin-top: 1rem; }
  .why__body {
    margin-top: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .why__body p {
    font-size: 1rem;
    color: var(--color-ink-2);
    line-height: 1.8;
    max-width: 60ch;
  }
  .why__body strong {
    color: var(--color-ink);
    font-weight: 600;
  }

  /* =================== AUDIENCE =================== */
  .audience {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .aud {
    border-radius: 24px;
    padding: clamp(1.75rem, 3vw, 2.25rem);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .aud__num {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.05rem;
    color: var(--color-deep);
    letter-spacing: 0.04em;
  }
  .aud__title {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 400;
    color: var(--color-ink);
    letter-spacing: -0.015em;
  }
  .aud__desc {
    font-size: 0.93rem;
    color: var(--color-ink-2);
    line-height: 1.7;
  }
  @media (max-width: 860px) {
    .audience { grid-template-columns: 1fr; }
  }

  /* =================== DELIVERABLES =================== */
  .deliverables {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .deliv {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 1.5rem;
    padding: 1.6rem 1.75rem;
    border-radius: 20px;
    align-items: start;
  }
  .deliv__num {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 2.1rem;
    color: var(--color-deep);
    font-weight: 300;
    line-height: 1;
  }
  .deliv__title {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 400;
    color: var(--color-ink);
    margin-bottom: 0.45rem;
    letter-spacing: -0.015em;
  }
  .deliv__desc {
    font-size: 0.96rem;
    color: var(--color-ink-2);
    line-height: 1.75;
  }
  @media (max-width: 560px) {
    .deliv { grid-template-columns: 1fr; gap: 0.5rem; }
  }

  /* =================== SAMPLE =================== */
  .sample {
    margin: 2.5rem auto 0;
    max-width: 800px;
    border-radius: 28px;
    padding: clamp(1rem, 3vw, 2rem);
  }
  .sample img {
    width: 100%;
    height: auto;
    aspect-ratio: 12 / 7;
    object-fit: contain;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.5);
    padding: clamp(0.5rem, 1.5vw, 1rem);
  }
  .sample figcaption {
    margin-top: 1rem;
    font-size: 0.82rem;
    color: var(--color-ink-2);
    text-align: center;
    letter-spacing: 0.02em;
  }

  /* =================== OUTCOMES =================== */
  .outcomes {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .outcome {
    display: grid;
    grid-template-columns: 44px 1fr;
    gap: 1.25rem;
    padding: 1.4rem 1.75rem;
    border-radius: 20px;
    align-items: start;
  }
  .outcome__tick {
    width: 36px;
    height: 36px;
    display: grid;
    place-items: center;
    background: rgba(236, 108, 135, 0.15);
    color: var(--color-deep);
    border-radius: 50%;
    flex-shrink: 0;
  }
  .outcome h3 {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--color-ink);
    margin-bottom: 0.3rem;
    letter-spacing: -0.015em;
  }
  .outcome p {
    font-size: 0.93rem;
    color: var(--color-ink-2);
    line-height: 1.65;
  }

  /* =================== PRICING =================== */
  .pricing-section { padding-top: clamp(2rem, 5vw, 4rem); }
  .pricing__card {
    max-width: 480px;
    margin: 2.5rem auto 0;
    border-radius: 32px;
    padding: clamp(2.25rem, 4.5vw, 3rem);
    text-align: center;
    position: relative;
  }
  .pricing__tag {
    display: inline-block;
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-deep);
    font-weight: 600;
    margin-bottom: 1rem;
  }
  .pricing__amt {
    font-family: var(--font-serif);
    font-size: clamp(2.8rem, 5.5vw, 3.6rem);
    font-weight: 300;
    color: var(--color-ink);
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .pricing__note {
    display: block;
    font-size: 0.82rem;
    color: var(--color-ink-2);
    margin: 0.7rem 0 1.6rem;
  }
  .pricing__features {
    list-style: none;
    padding: 1.4rem 0;
    margin: 0 0 1.6rem;
    border-top: 1px solid var(--color-hairline);
    border-bottom: 1px solid var(--color-hairline);
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    text-align: left;
  }
  .pricing__features li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.95rem;
    color: var(--color-ink);
  }
  .pricing__features svg {
    color: var(--color-deep);
    flex-shrink: 0;
  }
  .pricing__cta {
    width: 100%;
    justify-content: center;
  }
</style>
