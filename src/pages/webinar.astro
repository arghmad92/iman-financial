---
import Layout from '../layouts/Layout.astro';
import Accordion from '../components/Accordion.astro';

const learn = [
  { num: '01', title: 'Kenapa freelancer kena declare cukai', desc: 'Dan apa jadi kalau tak declare. Spoiler: LHDN boleh track income korang.' },
  { num: '02', title: 'Cara kira income & expenses', desc: 'Apa yang boleh claim sebagai business expense, phone bill, internet, equipment, travel, dan banyak lagi.' },
  { num: '03', title: 'Step-by-step isi e-Filing LHDN', desc: 'Dari register sampai submit. Live demo so korang boleh follow along.' },
  { num: '04', title: 'Cukai vs SSM vs PCB', desc: 'Beza semua ni dan mana yang wajib untuk korang sebagai freelancer atau content creator.' },
  { num: '05', title: 'Tips simpan duit untuk cukai', desc: 'Supaya tak panik bila musim tax. Simple system yang korang boleh start hari ni.' },
];

const forWho = [
  'Freelancer yang tak pernah declare cukai',
  'Content creator yang baru start earn income',
  'Side hustler yang confuse pasal tax',
  'Sesiapa yang nak faham e-Filing LHDN',
  'Yang dah kena surat LHDN dan tak tahu apa nak buat',
  'Yang nak belajar claim expenses properly',
];

const faqs = [
  { q: 'Akan ada recording tak?', a: 'Ya! Semua yang dah bayar akan dapat recording link via email dalam masa 48 jam selepas webinar. Link tu valid untuk 7 hari.' },
  { q: 'Boleh refund tak kalau tak boleh join?', a: 'Refund boleh dibuat sehingga 24 jam sebelum webinar. Lepas tu, korang akan dapat recording sebagai pengganti.' },
  { q: 'Kena ada background accounting ke?', a: 'Langsung tak perlu! Webinar ni memang untuk beginners. Kami explain semua dari basic.' },
  { q: 'Macam mana nak join on the day?', a: 'Korang akan dapat Zoom link via email selepas bayar. On the day, just click the link 5 minit sebelum start.' },
  { q: 'Ada Q&A session tak?', a: 'Yes! Last 15–20 minit will be open for Q&A. Korang boleh tanya apa-apa pasal cukai dan kewangan.' },
];
---

<Layout
  title="Cashflow Girlies · Webinar | Iman Abdul Rahim"
  description="Cara uruskan cukai for freelancers & content creators. Live webinar on 22 May 2026, 8PM."
>
  <!-- =================== HERO =================== -->
  <section class="hero">
    <div class="glow hero__glow-a" aria-hidden="true"></div>
    <div class="glow hero__glow-b" aria-hidden="true"></div>

    <div class="container-x hero__inner">
      <span class="hero__eyebrow">
        <span class="dot" aria-hidden="true"></span> Live Webinar
      </span>
      <h1 class="h-display h-display--xl hero__title text-balance">
        Cashflow <span class="pink">Girlies.</span>
      </h1>
      <p class="lede lede--xl lede--center hero__lede text-balance">
        Cara uruskan cukai untuk freelancers &amp; content creators. Tax rules,
        demystified, in plain language.
      </p>

      <p class="sr-only" id="webinar-meta">
        Webinar starts 22 May 2026 at 8 PM Malaysia time, hosted on Zoom.
      </p>

      <ul class="meta" aria-describedby="webinar-meta">
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" />
            <line x1="16" y1="2" x2="16" y2="6" />
            <line x1="8" y1="2" x2="8" y2="6" />
            <line x1="3" y1="10" x2="21" y2="10" />
          </svg>
          22 May 2026
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10" />
            <polyline points="12 6 12 12 16 14" />
          </svg>
          8:00 PM (MYT)
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="6" width="14" height="12" rx="2" />
            <polyline points="22 8 16 12 22 16 22 8" />
          </svg>
          Via Zoom
        </li>
      </ul>

      <div class="hero__actions">
        <a href="#register" class="btn btn--primary btn--lg">Secure my spot</a>
        <a href="#learn" class="btn btn--glass btn--lg btn--arrow">
          What you'll learn
        </a>
      </div>
    </div>
  </section>

  <!-- =================== COUNTDOWN — dramatic =================== -->
  <section class="section section--sm" id="countdown-section">
    <div class="container-tight">
      <div class="sec-head text-center sec-head--tight">
        <span class="eyebrow eyebrow--center">Event begins in</span>
      </div>

      <div class="countdown" id="countdown" aria-hidden="true">
        <div class="cd-cell">
          <span class="cd-num tabular" id="cdDays">--</span>
          <span class="cd-label">Days</span>
        </div>
        <span class="cd-sep" aria-hidden="true">:</span>
        <div class="cd-cell">
          <span class="cd-num tabular" id="cdHours">--</span>
          <span class="cd-label">Hours</span>
        </div>
        <span class="cd-sep" aria-hidden="true">:</span>
        <div class="cd-cell">
          <span class="cd-num tabular" id="cdMins">--</span>
          <span class="cd-label">Minutes</span>
        </div>
        <span class="cd-sep" aria-hidden="true">:</span>
        <div class="cd-cell">
          <span class="cd-num tabular" id="cdSecs">--</span>
          <span class="cd-label">Seconds</span>
        </div>
      </div>

      <p class="cd-footnote text-center">
        Early bird seats go fast &middot;
        <a href="#pricing" class="cd-link">See pricing</a>
      </p>
    </div>
  </section>

  <!-- =================== PRICING =================== -->
  <section class="section" id="pricing">
    <div class="container-x">
      <div class="sec-head text-center">
        <span class="eyebrow eyebrow--center">Pricing</span>
        <h2 class="h-section text-balance">
          Pilih seat <span class="pink">korang.</span>
        </h2>
        <p class="lede lede--center text-balance">
          Early bird RM29 for the first 20 seats. After that, regular pricing
          applies.
        </p>
      </div>

      <div class="pricing-grid">
        <div class="pricing-card pricing-card--featured" data-tier="early-bird">
          <div class="pricing-card__head">
            <span class="badge badge--pink">Early bird</span>
            <span class="pricing-card__note" data-eb-note>First 20 seats only</span>
          </div>
          <div class="pricing-card__amt">
            <span class="pricing-card__currency">RM</span>
            <span class="pricing-card__num tabular">29</span>
          </div>
          <ul class="pricing-card__features">
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Live 90-min webinar
            </li>
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Recording for 7 days
            </li>
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Live Q&amp;A session
            </li>
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              e-Filing checklist (PDF)
            </li>
          </ul>
          <a href="#register" class="btn btn--primary btn--full btn--arrow">
            Secure my spot
          </a>
        </div>

        <div class="pricing-card">
          <div class="pricing-card__head">
            <span class="badge">Regular</span>
            <span class="pricing-card__note">After first 20 seats</span>
          </div>
          <div class="pricing-card__amt">
            <span class="pricing-card__currency">RM</span>
            <span class="pricing-card__num tabular">39</span>
          </div>
          <ul class="pricing-card__features">
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Live 90-min webinar
            </li>
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Recording for 7 days
            </li>
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Live Q&amp;A session
            </li>
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              e-Filing checklist (PDF)
            </li>
          </ul>
          <a href="#register" class="btn btn--outline btn--full">
            Register
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- =================== LEARN — bento (first card wide) =================== -->
  <section class="section" id="learn">
    <div class="container-x">
      <div class="sec-head text-center">
        <span class="eyebrow eyebrow--center">What you'll learn</span>
        <h2 class="h-section text-balance">
          Benda yang <span class="pink">korang kena tahu.</span>
        </h2>
        <p class="lede lede--center text-balance">
          Tak kisah korang baru start freelance atau dah lama buat content,
          cukai ni benda yang ramai ignore sampai kena penalty.
        </p>
      </div>

      <ul class="bento-feat">
        {learn.map((l, idx) => (
          <li class:list={['bento-feat__card', idx === 0 && 'bento-feat__card--wide']}>
            <span class="bento-feat__num">{l.num}</span>
            <h3 class="bento-feat__title">{l.title}</h3>
            <p class="bento-feat__desc">{l.desc}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- =================== WHO — checklist card =================== -->
  <section class="section">
    <div class="container-tight">
      <div class="sec-head text-center">
        <span class="eyebrow eyebrow--center">Who it's for</span>
        <h2 class="h-section text-balance">
          Webinar ni untuk korang <span class="pink">kalau…</span>
        </h2>
      </div>

      <div class="who-card glass-strong">
        <ul class="who-list">
          {forWho.map((w) => (
            <li class="who-item">
              <span class="who-item__tick" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
              </span>
              <span>{w}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- =================== SPEAKER =================== -->
  <section class="section">
    <div class="container-tight">
      <div class="speaker">
        <span class="eyebrow" style="color:#f0a8bc">Your host</span>
        <h2 class="h-section speaker__title text-balance">
          Iman <span class="cta-pink">Abdul Rahim.</span>
        </h2>
        <p class="speaker__desc">
          Licensed Financial Planner (CFP, IFP) yang dah bantu ramai Malaysians
          uruskan kewangan. From budgeting basics to full financial planning, I
          simplify the complicated stuff so korang boleh focus on buat duit.
        </p>
        <div class="speaker__chips">
          <span class="badge badge--on-ink">CFP® Certified</span>
          <span class="badge badge--on-ink">SC Licensed</span>
          <span class="badge badge--on-ink">BNM Licensed</span>
        </div>
      </div>
    </div>
  </section>

  <!-- =================== REGISTER =================== -->
  <section class="section" id="register">
    <div class="container-narrow">
      <div class="sec-head text-center">
        <span class="eyebrow eyebrow--center">Register</span>
        <h2 class="h-section text-balance">
          Secure your <span class="pink">spot.</span>
        </h2>
        <p class="lede lede--center">
          Early bird RM29 for the first 20. After that, it's RM39.
        </p>
      </div>

      <form class="reg glass-strong" id="regForm" novalidate>
        <div class="field">
          <label for="regName" class="field__label">Full name</label>
          <input type="text" class="input" id="regName" name="name" placeholder="e.g. Siti Nurhaliza" required autocomplete="name" autocapitalize="words" />
        </div>
        <div class="field">
          <label for="regEmail" class="field__label">Email</label>
          <input type="email" class="input" id="regEmail" name="email" placeholder="siti@gmail.com" required autocomplete="email" inputmode="email" />
        </div>
        <div class="field">
          <label for="regPhone" class="field__label">Phone (WhatsApp)</label>
          <input type="tel" class="input" id="regPhone" name="phone" placeholder="0123456789" required autocomplete="tel" inputmode="tel" />
        </div>

        <div id="regError" class="alert alert--error" role="alert" aria-live="polite" hidden>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="8" x2="12" y2="12"></line>
            <line x1="12" y1="16" x2="12.01" y2="16"></line>
          </svg>
          <span id="regErrorText"></span>
        </div>

        <button type="submit" class="btn btn--primary btn--lg btn--full" id="regBtn" data-default-price="29">
          Register &amp; Pay · RM<span data-price>29</span>
        </button>
        <p class="reg__note">
          You'll be redirected to ToyyibPay for secure payment via FPX. Zoom
          link sent to your email after payment.
        </p>
      </form>
    </div>
  </section>

  <!-- =================== FAQ =================== -->
  <section class="section">
    <div class="container-tight">
      <div class="sec-head">
        <span class="eyebrow">FAQ</span>
        <h2 class="h-section text-balance">
          Soalan <span class="pink">lazim.</span>
        </h2>
      </div>
      <div class="faq-card glass-strong">
        <Accordion items={faqs} />
      </div>
    </div>
  </section>

  <!-- =================== FINAL CTA =================== -->
  <section class="section">
    <div class="container-narrow">
      <div class="finalcta">
        <span class="eyebrow" style="color:#f0a8bc">Don't miss out</span>
        <h2 class="h-section finalcta__title text-balance">
          Jangan tunggu sampai <span class="cta-pink">kena penalty.</span>
        </h2>
        <p class="finalcta__sub">
          RM29 je untuk ilmu yang boleh save korang thousands. Limited seats.
        </p>
        <a href="#register" class="btn btn--on-ink btn--lg btn--arrow">Secure my spot</a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const target = new Date('2026-05-22T20:00:00+08:00').getTime();
  const el = document.getElementById('countdown');
  const $d = document.getElementById('cdDays');
  const $h = document.getElementById('cdHours');
  const $m = document.getElementById('cdMins');
  const $s = document.getElementById('cdSecs');
  function tick() {
    if (!el) return;
    const diff = target - Date.now();
    if (diff <= 0) {
      el.innerHTML = '<p class="cd-done">Webinar has started!</p>';
      return;
    }
    const d = Math.floor(diff / 86400000);
    const h = Math.floor((diff % 86400000) / 3600000);
    const m = Math.floor((diff % 3600000) / 60000);
    const s = Math.floor((diff % 60000) / 1000);
    if ($d) $d.textContent = String(d).padStart(2, '0');
    if ($h) $h.textContent = String(h).padStart(2, '0');
    if ($m) $m.textContent = String(m).padStart(2, '0');
    if ($s) $s.textContent = String(s).padStart(2, '0');
  }
  tick();
  setInterval(tick, 1000);

  // --- Seat availability — update tier note + button price dynamically ---
  let currentPrice = '29';
  async function loadSeats() {
    try {
      const res = await fetch('/api/seats', { cache: 'no-store' });
      if (!res.ok) return;
      const { remaining, total, soldOut } = await res.json();

      // Update early-bird tier copy
      const note = document.querySelector('[data-eb-note]') as HTMLElement | null;
      if (note) {
        note.textContent = soldOut
          ? 'Early bird sold out'
          : `${remaining} of ${total} seats left`;
      }

      // Update featured tier visual + button price if sold out
      const tier = document.querySelector('[data-tier="early-bird"]');
      const priceEl = document.querySelector('[data-price]') as HTMLElement | null;
      if (soldOut) {
        tier?.classList.add('is-soldout');
        currentPrice = '39';
        if (priceEl) priceEl.textContent = '39';
      } else {
        currentPrice = '29';
        if (priceEl) priceEl.textContent = '29';
      }
    } catch {
      // Endpoint not available (e.g. local astro dev) — leave defaults.
    }
  }
  loadSeats();

  function resetBtn() {
    const btn = document.getElementById('regBtn') as HTMLButtonElement | null;
    if (!btn) return;
    btn.disabled = false;
    btn.innerHTML = `Register &amp; Pay · RM<span data-price>${currentPrice}</span>`;
  }

  const form = document.getElementById('regForm') as HTMLFormElement | null;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('regBtn') as HTMLButtonElement;
    const errEl = document.getElementById('regError') as HTMLElement;
    const errText = document.getElementById('regErrorText') as HTMLElement;
    errEl.hidden = true;

    const name = (document.getElementById('regName') as HTMLInputElement).value.trim();
    const email = (document.getElementById('regEmail') as HTMLInputElement).value.trim();
    const phone = (document.getElementById('regPhone') as HTMLInputElement).value.trim();

    if (!name || !email || !phone) {
      errEl.hidden = false;
      errText.textContent = 'Please fill in all fields.';
      return;
    }
    btn.disabled = true;
    btn.textContent = 'Processing…';

    try {
      const res = await fetch('/api/register-webinar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, phone }),
      });
      const data = await res.json();
      if (data.paymentUrl) {
        window.location.href = data.paymentUrl;
      } else {
        errEl.hidden = false;
        errText.textContent = data.error || 'Something went wrong. Please try again.';
        resetBtn();
      }
    } catch {
      errEl.hidden = false;
      errText.textContent = 'Connection error. Please try again.';
      resetBtn();
    }
  });
</script>

<style>
  /* ---------- Hero ---------- */
  .hero {
    padding: clamp(3rem, 6vw, 6rem) 0 clamp(2rem, 4vw, 3rem);
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }
  .hero__glow-a {
    width: 640px; height: 640px; top: -180px; right: -160px;
    background: radial-gradient(circle, rgba(196, 69, 105, 0.08), transparent 65%);
    z-index: -1;
  }
  .hero__glow-b {
    width: 520px; height: 520px; bottom: -160px; left: -160px;
    background: radial-gradient(circle, rgba(249, 212, 220, 0.25), transparent 65%);
    z-index: -1;
  }
  .hero__inner {
    text-align: center;
    position: relative; z-index: 1;
  }
  .hero__eyebrow {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.45rem 1rem;
    background: var(--glass-strong);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-primary);
    margin-bottom: 1.75rem;
    box-shadow: var(--shadow-glass);
  }
  .dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--color-primary);
    box-shadow: 0 0 0 4px rgba(196, 69, 105, 0.16);
  }
  .hero__title { margin: 0 auto; }
  .hero__lede { margin: 1.75rem auto 2rem; }

  .meta {
    list-style: none; padding: 0;
    margin: 0 auto 2.5rem;
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    justify-content: center;
    align-items: stretch;
    padding: 0.4rem;
    background: var(--glass-strong);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: 999px;
    box-shadow: var(--shadow-glass);
  }
  .meta li {
    display: inline-flex; align-items: center;
    gap: 0.45rem;
    padding: 0.4rem 0.9rem;
    color: var(--color-foreground);
    font-size: 0.88rem;
    font-weight: 500;
  }
  .meta svg {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .hero__actions {
    display: flex; gap: 0.75rem; flex-wrap: wrap;
    justify-content: center;
  }

  /* ---------- Countdown (dramatic) ---------- */
  .sec-head--tight {
    margin-bottom: 1.75rem !important;
  }
  .countdown {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
    align-items: center;
    gap: clamp(0.5rem, 1.5vw, 1.25rem);
    padding: clamp(1.5rem, 3.5vw, 2.5rem) clamp(1.5rem, 3vw, 2.5rem);
    background: var(--glass-strong);
    backdrop-filter: var(--glass-blur-strong);
    -webkit-backdrop-filter: var(--glass-blur-strong);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-3xl);
    box-shadow: var(--shadow-glass-lg);
    max-width: 720px;
    margin: 0 auto;
  }
  .cd-cell {
    display: flex; flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    text-align: center;
  }
  .cd-num {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 7vw, 4.6rem);
    font-weight: 600;
    color: var(--color-foreground);
    letter-spacing: -0.05em;
    line-height: 0.9;
  }
  .cd-label {
    font-size: clamp(0.62rem, 1.1vw, 0.74rem);
    color: var(--color-muted-foreground);
    font-weight: 500;
    letter-spacing: 0.04em;
  }
  .cd-sep {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.4rem);
    color: var(--color-primary);
    font-weight: 300;
    line-height: 0.9;
