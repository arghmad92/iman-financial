      border-color 0.2s ease;
  }
  .whogrid li:hover {
    color: var(--ink);
    border-color: var(--ink);
  }

  /* =================== SPEAKER =================== */
  .speaker {
    background: var(--ink);
  }
  .speaker__grid {
    max-width: 620px;
  }
  .speaker__desc {
    margin-top: 1.25rem;
    font-size: 1rem;
    color: rgba(250, 234, 237, 0.72);
    line-height: 1.75;
    margin-bottom: 1.5rem;
    max-width: 58ch;
  }
  .speaker__chips {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  /* =================== REGISTRATION =================== */
  .reg {
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    padding: clamp(1.5rem, 3vw, 2.25rem);
