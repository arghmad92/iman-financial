    font-weight: 400;
    display: block;
    margin-bottom: 0.8rem;
    line-height: 1;
  }
  .lcard__title {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }
  .lcard__desc {
    font-size: 0.9rem;
    color: var(--text-2);
    line-height: 1.7;
  }
