    text-align: left;
    min-width: 140px;
    opacity: 0.6;
  }
  .tier--featured {
    opacity: 1;
    border-color: var(--ink);
    background: var(--ink);
    color: var(--cream);
  }
  .tier__label {
    display: block;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--rose-deep);
    margin-bottom: 0.3rem;
  }
  .tier--featured .tier__label {
    color: var(--rose-soft);
  }
  .tier__amt {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.01em;
  }
  .tier__note {
    display: block;
    font-size: 0.72rem;
    color: var(--text-3);
    margin-top: 0.3rem;
  }
  .tier--featured .tier__note {
    color: rgba(250, 234, 237, 0.6);
  }
  .hero__small {
    font-size: 0.78rem;
    color: var(--text-3);
    margin-top: 1rem;
    font-style: italic;
  }

  /* =================== LEARN =================== */
  .learn {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .lcard {
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
