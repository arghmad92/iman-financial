    .learn {
      grid-template-columns: 1fr;
    }
  }

  /* =================== WHO =================== */
  .whogrid {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
  }
