  }
  .reg__input:focus {
    border-color: var(--ink);
    box-shadow: 0 0 0 3px var(--rose-tint);
  }
  .reg__input::placeholder {
    color: var(--text-3);
  }
  .reg__error {
    color: var(--rose-deep);
    font-size: 0.86rem;
    background: var(--rose-tint);
    padding: 0.7rem 1rem;
    border-radius: var(--r-sm);
    margin-bottom: 1rem;
