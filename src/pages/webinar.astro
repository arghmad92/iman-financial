---
import Layout from '../layouts/Layout.astro';

const learn = [
  {
    num: '01',
    title: 'Kenapa freelancer kena declare cukai',
    desc: 'Dan apa jadi kalau tak declare. Spoiler: LHDN boleh track income korang.',
  },
  {
    num: '02',
    title: 'Cara kira income & expenses',
    desc: 'Apa yang boleh claim sebagai business expense, phone bill, internet, equipment, travel, dan banyak lagi.',
  },
  {
    num: '03',
    title: 'Step-by-step isi e-Filing LHDN',
    desc: 'Dari register sampai submit. Live demo so korang boleh follow along.',
  },
  {
    num: '04',
    title: 'Cukai vs SSM vs PCB',
    desc: 'Beza semua ni dan mana yang wajib untuk korang sebagai freelancer atau content creator.',
  },
  {
    num: '05',
    title: 'Tips simpan duit untuk cukai',
    desc: 'Supaya tak panik bila musim tax. Simple system yang korang boleh start hari ni.',
  },
];

const forWho = [
  'Freelancer yang tak pernah declare cukai',
  'Content creator yang baru start earn income',
  'Side hustler yang confuse pasal tax',
  'Sesiapa yang nak faham e-Filing LHDN',
  'Yang dah kena surat LHDN dan tak tahu apa nak buat',
  'Yang nak belajar claim expenses properly',
];

const faqs = [
  {
    q: 'Akan ada recording tak?',
    a: 'Ya! Semua yang dah bayar akan dapat recording link via email dalam masa 48 jam selepas webinar. Link tu valid untuk 7 hari.',
  },
  {
    q: 'Boleh refund tak kalau tak boleh join?',
    a: 'Refund boleh dibuat sehingga 24 jam sebelum webinar. Lepas tu, korang akan dapat recording sebagai pengganti.',
  },
  {
    q: 'Kena ada background accounting ke?',
    a: 'Langsung tak perlu! Webinar ni memang untuk beginners. Kami explain semua dari basic.',
  },
  {
    q: 'Macam mana nak join on the day?',
    a: 'Korang akan dapat Zoom link via email selepas bayar. On the day, just click the link 5 minit sebelum start.',
  },
  {
    q: 'Ada Q&A session tak?',
    a: 'Yes! Last 15–20 minit will be open for Q&A. Korang boleh tanya apa-apa pasal cukai dan kewangan.',
  },
];
---

<Layout
  title="Cashflow Girlies · Webinar | Iman Abdul Rahim"
  description="Cara uruskan cukai for freelancers & content creators. Live webinar on 10 April 2026, 8PM."
>
  <!-- =================== HERO =================== -->
  <section class="hero">
    <div class="glow glow--a" aria-hidden="true"></div>
    <div class="glow glow--b" aria-hidden="true"></div>
    <div class="glow glow--c" aria-hidden="true"></div>

    <div class="container-x hero__inner text-center">
      <span class="chip chip--rose hero__chip">● Live Webinar</span>
      <h1 class="h-display hero__title">
        Cashflow <em>Girlies.</em>
      </h1>
      <p class="lede lede--center hero__lede">
        Cara uruskan cukai untuk freelancers &amp; content creators. Tax rules,
        demystified, in plain language.
      </p>

      <ul class="hero__meta">
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          10 April 2026
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          8:00 PM (MYT)
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M15 10l5 5-5 5"/><path d="M4 4v7a4 4 0 0 0 4 4h12"/></svg>
          Via Zoom
        </li>
      </ul>

      <!-- Countdown -->
      <div class="countdown glass" id="countdown" aria-live="polite">
        <div class="cd-item">
          <span class="cd-num" id="cdDays">--</span>
          <span class="cd-label">Days</span>
        </div>
        <div class="cd-sep" aria-hidden="true">·</div>
        <div class="cd-item">
          <span class="cd-num" id="cdHours">--</span>
          <span class="cd-label">Hrs</span>
        </div>
        <div class="cd-sep" aria-hidden="true">·</div>
        <div class="cd-item">
          <span class="cd-num" id="cdMins">--</span>
          <span class="cd-label">Min</span>
        </div>
        <div class="cd-sep" aria-hidden="true">·</div>
        <div class="cd-item">
          <span class="cd-num" id="cdSecs">--</span>
          <span class="cd-label">Sec</span>
        </div>
      </div>

      <div class="tiers">
        <div class="tier tier--featured">
          <span class="tier__label">Early bird</span>
          <span class="tier__amt">RM29</span>
          <span class="tier__note">First 20 seats only</span>
        </div>
        <div class="tier glass">
          <span class="tier__label">Regular</span>
          <span class="tier__amt"><s>RM39</s></span>
          <span class="tier__note">After first 20</span>
        </div>
      </div>

      <a href="#register" class="btn btn--rose btn--lg">Secure my spot</a>
      <p class="hero__small">Limited seats available · Secure payment via FPX</p>
    </div>
  </section>

  <!-- =================== LEARN =================== -->
  <section class="section" id="learn">
    <div class="container-x">
      <div class="section__intro">
        <span class="eyebrow">What you'll learn</span>
        <h2 class="h-section">
          Benda yang <em>korang kena tahu.</em>
        </h2>
        <p class="lede">
          Tak kisah korang baru start freelance atau dah lama buat content, cukai ni benda yang ramai ignore sampai kena penalty.
        </p>
      </div>

      <ul class="learn">
        {
          learn.map((l) => (
            <li class="lcard glass">
              <span class="lcard__num">{l.num}</span>
              <h3 class="lcard__title">{l.title}</h3>
              <p class="lcard__desc">{l.desc}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- =================== FOR WHO =================== -->
  <section class="section">
    <div class="container-tight text-center">
      <span class="eyebrow eyebrow--center">Who it's for</span>
      <h2 class="h-section" style="margin-top:1rem">
        Webinar ni untuk korang <em>kalau…</em>
      </h2>

      <ul class="whogrid">
        {forWho.map((w) => <li class="glass">{w}</li>)}
      </ul>
    </div>
  </section>

  <!-- =================== SPEAKER =================== -->
  <section class="section">
    <div class="container-tight">
      <div class="speaker glass-ink">
        <div class="speaker__grid">
          <div>
            <span class="eyebrow eyebrow--light">Your host</span>
            <h2 class="h-section speaker__title">
              Iman <em>Abdul Rahim.</em>
            </h2>
            <p class="speaker__desc">
              Licensed Financial Planner (CFP, IFP) yang dah bantu ramai
              Malaysians uruskan kewangan. From budgeting basics to full
              financial planning, I simplify the complicated stuff so korang
              boleh focus on buat duit.
            </p>
            <div class="speaker__chips">
              <span class="chip chip--on-dark">CFP® Certified</span>
              <span class="chip chip--on-dark">SC Licensed</span>
              <span class="chip chip--on-dark">BNM Licensed</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- =================== REGISTRATION =================== -->
  <section class="section" id="register">
    <div class="container-narrow">
      <div class="section__intro section__intro--center">
        <span class="eyebrow eyebrow--center">Register</span>
        <h2 class="h-section">
          Secure your <em>spot.</em>
        </h2>
        <p class="lede lede--center">
          Early bird RM29 for the first 20. After that, it's RM39.
        </p>
      </div>

      <form class="reg glass" id="regForm">
        <div class="reg__group">
          <label for="regName" class="reg__label">Full name</label>
          <input
            type="text"
            class="reg__input"
            id="regName"
            placeholder="e.g. Siti Nurhaliza"
            required
            style="text-transform:capitalize"
            autocapitalize="words"
          />
        </div>
        <div class="reg__group">
          <label for="regEmail" class="reg__label">Email</label>
          <input
            type="email"
            class="reg__input"
            id="regEmail"
            placeholder="siti@gmail.com"
            required
          />
        </div>
        <div class="reg__group">
          <label for="regPhone" class="reg__label">Phone (WhatsApp)</label>
          <input
            type="tel"
            class="reg__input"
            id="regPhone"
            placeholder="0123456789"
            required
          />
        </div>

        <div id="regError" class="reg__error" style="display:none"></div>

        <button type="submit" class="btn btn--rose btn--lg reg__btn" id="regBtn">
          Register &amp; Pay · RM29
        </button>
        <p class="reg__note">
          You'll be redirected to ToyyibPay for secure payment via FPX. Zoom
          link sent to your email after payment.
        </p>
      </form>
    </div>
  </section>

  <!-- =================== FAQ =================== -->
  <section class="section">
    <div class="container-tight">
      <div class="faq-card glass">
        <div class="section__intro">
          <span class="eyebrow">FAQ</span>
          <h2 class="h-section">
            Soalan <em>lazim.</em>
          </h2>
        </div>
        <div class="faq">
          {
            faqs.map((f) => (
              <details>
                <summary>{f.q}</summary>
                <div class="faq__a">
                  <p>{f.a}</p>
                </div>
              </details>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- =================== FINAL CTA =================== -->
  <section class="section">
    <div class="container-narrow">
      <div class="finalcta glass-ink text-center">
        <span class="eyebrow eyebrow--center eyebrow--light">Don't miss out</span>
        <h2 class="h-section finalcta__title">
          Jangan tunggu sampai<br /><em>kena penalty.</em>
        </h2>
        <p class="finalcta__sub">
          RM29 je untuk ilmu yang boleh save korang thousands. Limited seats.
        </p>
        <a href="#register" class="btn btn--on-dark btn--lg">Secure my spot</a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const target = new Date('2026-04-10T20:00:00+08:00').getTime();
  function updateCountdown() {
    const now = Date.now();
    const diff = target - now;
    const el = document.getElementById('countdown');
    if (!el) return;
    if (diff <= 0) {
      el.innerHTML =
        '<p style="color:var(--color-deep);font-weight:500;font-family:var(--font-serif);font-size:1.2rem;padding:0.5rem 1rem">Webinar has started!</p>';
      return;
    }
    const d = Math.floor(diff / (1000 * 60 * 60 * 24));
    const h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    const s = Math.floor((diff % (1000 * 60)) / 1000);
    document.getElementById('cdDays')!.textContent = String(d).padStart(2, '0');
    document.getElementById('cdHours')!.textContent = String(h).padStart(2, '0');
    document.getElementById('cdMins')!.textContent = String(m).padStart(2, '0');
    document.getElementById('cdSecs')!.textContent = String(s).padStart(2, '0');
  }
  updateCountdown();
  setInterval(updateCountdown, 1000);

  document.getElementById('regForm')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('regBtn') as HTMLButtonElement;
    const errEl = document.getElementById('regError')!;
    errEl.style.display = 'none';

    const name = (document.getElementById('regName') as HTMLInputElement).value.trim();
    const email = (document.getElementById('regEmail') as HTMLInputElement).value.trim();
    const phone = (document.getElementById('regPhone') as HTMLInputElement).value.trim();

    if (!name || !email || !phone) {
      errEl.style.display = '';
      errEl.textContent = 'Please fill in all fields.';
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Processing…';

    try {
      const res = await fetch('/api/register-webinar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, phone }),
      });
      const data = await res.json();

      if (data.paymentUrl) {
        window.location.href = data.paymentUrl;
      } else {
        errEl.style.display = '';
        errEl.textContent = data.error || 'Something went wrong. Please try again.';
        btn.disabled = false;
        btn.textContent = 'Register & Pay · RM29';
      }
    } catch {
      errEl.style.display = '';
      errEl.textContent = 'Connection error. Please try again.';
      btn.disabled = false;
      btn.textContent = 'Register & Pay · RM29';
    }
  });
</script>

<style>
  /* =================== HERO =================== */
  .hero {
    position: relative;
    padding: clamp(8rem, 14vw, 12rem) 0 clamp(4rem, 7vw, 6rem);
    overflow: hidden;
    isolation: isolate;
  }
  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    pointer-events: none;
    z-index: -1;
  }
  .glow--a {
    width: 480px;
    height: 480px;
    top: -100px;
    right: -100px;
    background: radial-gradient(circle, rgba(236, 108, 135, 0.18), transparent 70%);
  }
  .glow--b {
    width: 420px;
    height: 420px;
    bottom: -100px;
    left: -120px;
    background: radial-gradient(circle, rgba(244, 163, 179, 0.14), transparent 70%);
  }
  .glow--c {
