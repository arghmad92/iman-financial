  .reg__group {
    margin-bottom: 1rem;
  }
  .reg__label {
    display: block;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 0.4rem;
    letter-spacing: 0.02em;
  }
  .reg__input {
    width: 100%;
    padding: 0.85rem 1rem;
    border: 1px solid var(--border-strong);
    border-radius: var(--r-sm);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--ink);
    background: var(--paper);
    outline: none;
    transition:
      border-color 0.2s ease,
