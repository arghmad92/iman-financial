---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Payment Successful · Cashflow Girlies"
  description="Your registration is confirmed!"
>
  <section class="success">
    <div class="glow glow--a" aria-hidden="true"></div>
    <div class="glow glow--b" aria-hidden="true"></div>

    <div class="container-narrow text-center">
      <span class="success__icon glass-pink" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12" />
        </svg>
      </span>

      <span class="eyebrow eyebrow--center">Registration confirmed</span>
      <h1 class="h-display success__title">
        You're <em>in.</em>
      </h1>
      <p class="lede lede--center success__sub">
        Payment confirmed. Check your email for confirmation details, Zoom
        link goes out 1 day before the webinar.
      </p>

      <div class="success__card glass">
        <span class="chip chip--rose">Cashflow Girlies</span>
        <h3>Cara uruskan cukai for freelancers &amp; content creators</h3>
        <dl class="success__meta">
          <div>
            <dt>Date</dt>
            <dd>10 April 2026</dd>
          </div>
          <div>
            <dt>Time</dt>
            <dd>8:00 PM (MYT)</dd>
          </div>
          <div>
            <dt>Platform</dt>
            <dd>Zoom</dd>
          </div>
        </dl>
      </div>

      <div class="success__actions">
        <a href="/webinar" class="btn btn--ghost">Back to webinar</a>
        <a
          href="https://wa.me/60186617981?text=Hi%20Iman!%20I%20just%20registered%20for%20Cashflow%20Girlies%20webinar"
          target="_blank"
          rel="noopener"
          class="btn btn--wa"
        >
          Say hi on WhatsApp
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .success {
    position: relative;
    min-height: calc(100vh - 120px);
    display: flex;
    align-items: center;
    padding: clamp(7rem, 12vw, 10rem) 0 clamp(4rem, 7vw, 6rem);
    overflow: hidden;
    isolation: isolate;
  }
  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    pointer-events: none;
    z-index: -1;
  }
  .glow--a {
    width: 540px;
    height: 540px;
    top: -160px;
    right: -120px;
    background: radial-gradient(circle, rgba(236, 108, 135, 0.16), transparent 70%);
  }
  .glow--b {
    width: 460px;
    height: 460px;
    bottom: -120px;
    left: -120px;
    background: radial-gradient(circle, rgba(244, 163, 179, 0.14), transparent 70%);
  }
  .success__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    color: var(--color-deep);
    margin-bottom: 1.75rem;
  }
  .success__title {
    margin-bottom: 1.25rem;
  }
  .success__sub {
    margin-bottom: 2.5rem;
  }
  .success__card {
    text-align: left;
    max-width: 480px;
    margin: 0 auto 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: clamp(1.5rem, 3vw, 2rem);
    border-radius: 24px;
  }
  .success__card h3 {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--color-ink);
    letter-spacing: -0.02em;
    line-height: 1.3;
  }
  .success__meta {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-hairline);
    margin: 0;
  }
  .success__meta div {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .success__meta dt {
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-deep);
    font-weight: 600;
  }
  .success__meta dd {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--color-ink);
    margin: 0;
  }
  .success__actions {
    display: flex;
    gap: 0.8rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 480px) {
    .success__meta { grid-template-columns: 1fr; }
  }
</style>
