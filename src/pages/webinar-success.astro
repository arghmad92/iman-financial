---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Payment Successful · Cashflow Girlies"
  description="Your registration is confirmed!"
>
  <section class="success">
    <div class="container container--narrow text-center">
      <span class="success__icon" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12" />
        </svg>
      </span>

      <span class="eyebrow eyebrow--center">Registration confirmed</span>
      <h1 class="h-display success__title">
        You're <em>in.</em>
      </h1>
      <p class="lede lede--center success__sub">
        Payment confirmed. Check your email for confirmation details, Zoom
        link goes out 1 day before the webinar.
      </p>

      <div class="success__card card card--cream">
        <span class="chip chip--rose">Cashflow Girlies</span>
        <h3>Cara uruskan cukai for freelancers &amp; content creators</h3>
        <dl class="success__meta">
          <div>
            <dt>Date</dt>
            <dd>10 April 2026</dd>
          </div>
          <div>
            <dt>Time</dt>
            <dd>8:00 PM (MYT)</dd>
          </div>
          <div>
            <dt>Platform</dt>
            <dd>Zoom</dd>
          </div>
        </dl>
      </div>

      <div class="success__actions">
        <a href="/webinar" class="btn btn--ghost">Back to webinar</a>
        <a
          href="https://wa.me/60186617981?text=Hi%20Iman!%20I%20just%20registered%20for%20Cashflow%20Girlies%20webinar"
          target="_blank"
          rel="noopener"
          class="btn btn--wa"
        >
          Say hi on WhatsApp
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .success {
    min-height: calc(100vh - 120px);
    display: flex;
    align-items: center;
    padding: clamp(7rem, 12vw, 10rem) 0 clamp(4rem, 7vw, 6rem);
    background:
      radial-gradient(circle at 50% -5%, var(--rose-tint) 0%, transparent 40%),
      var(--cream);
  }
  .success__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: var(--ink);
    color: var(--cream);
    margin-bottom: 1.75rem;
    box-shadow: 0 6px 18px rgba(22, 26, 40, 0.15);
  }
  .success__title {
    margin-bottom: 1.25rem;
  }
  .success__sub {
    margin-bottom: 2.5rem;
  }
  .success__card {
    text-align: left;
    max-width: 440px;
    margin: 0 auto 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .success__card h3 {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.01em;
    line-height: 1.3;
  }
  .success__meta {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--hairline);
    margin: 0;
  }
  .success__meta div {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .success__meta dt {
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-3);
    font-weight: 600;
  }
  .success__meta dd {
    font-family: var(--font-serif);
    font-size: 0.96rem;
    color: var(--ink);
    margin: 0;
  }
  .success__actions {
    display: flex;
    gap: 0.8rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 480px) {
    .success__meta {
      grid-template-columns: 1fr;
    }
  }
</style>
