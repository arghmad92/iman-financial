---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container-x">
    <div class="footer-card">
      <div class="footer-top">
        <div class="footer-brand">
          <span class="footer-logo">Iman Abdul Rahim</span>
          <span class="footer-tagline">Licensed Financial Planner · CFP® · IFP</span>
        </div>

        <div class="footer-col">
          <span class="footer-col-title">Services</span>
          <a href="/planning">Full Financial Planning</a>
          <a href="/fhc">Financial Health Check</a>
          <a href="/webinar">Cashflow Girlies Webinar</a>
        </div>

        <div class="footer-col">
          <span class="footer-col-title">Connect</span>
          <a href="https://wa.me/60186617981" target="_blank" rel="noopener">WhatsApp</a>
          <a href="https://www.instagram.com/imanabdulrahim" target="_blank" rel="noopener">Instagram</a>
        </div>
      </div>

      <div class="footer-bottom">
        <p>&copy; {year} Iman Abdul Rahim. All rights reserved.</p>
        <p class="footer-fineprint">Licensed by Securities Commission Malaysia & Bank Negara Malaysia.</p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 0 0 clamp(1rem, 3vw, 2rem);
    margin-top: clamp(2rem, 5vw, 4rem);
  }

  .footer-card {
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: saturate(170%) blur(22px);
    -webkit-backdrop-filter: saturate(170%) blur(22px);
    border: 1px solid rgba(255, 255, 255, 0.65);
    border-radius: 32px;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.5) inset,
      0 12px 40px -12px rgba(138, 46, 74, 0.12);
    padding: clamp(2.5rem, 5vw, 3.5rem) clamp(1.75rem, 4vw, 3rem) 1.75rem;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--color-hairline);
  }

  .footer-brand {
    max-width: 420px;
  }
  .footer-logo {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin-bottom: 0.3rem;
  }
  .footer-tagline {
    display: block;
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-deep);
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .footer-col-title {
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-deep);
    font-weight: 600;
    margin-bottom: 0.3rem;
  }
  .footer-col a {
    font-size: 0.92rem;
    color: var(--color-ink-2);
    transition: color 0.2s ease;
  }
  .footer-col a:hover {
    color: var(--color-deep);
  }

  .footer-bottom {
    padding-top: 1.5rem;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: 0.78rem;
    color: var(--color-ink-3);
  }
  .footer-fineprint {
    color: var(--color-ink-3);
  }

  @media (max-width: 768px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
