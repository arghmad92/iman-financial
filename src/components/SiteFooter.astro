---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container-x">
    <div class="footer__inner">
      <div class="footer__brand">
        <span class="footer__logo">Iman <span class="footer__dot">.</span></span>
        <p class="footer__about">
          Personalised, unbiased financial planning for Malaysians.<br />
          Licensed by Securities Commission Malaysia &amp; Bank Negara Malaysia.
        </p>
      </div>

      <div class="footer__cols">
        <div class="footer__col">
          <span class="footer__col-title">Services</span>
          <a href="/planning">Full Financial Planning</a>
          <a href="/fhc">Financial Health Check</a>
          <a href="/webinar">Cashflow Girlies Webinar</a>
        </div>

        <div class="footer__col">
          <span class="footer__col-title">Connect</span>
          <a
            href="https://form.wealthvantage.com.my/iman-lead/"
            target="_blank"
            rel="noopener">Book a call</a
          >
          <a
            href="https://www.instagram.com/imanabdulrahim"
            target="_blank"
            rel="noopener">Instagram</a
          >
        </div>
      </div>
    </div>

    <div class="footer__bottom">
      <p>&copy; {year} Iman Abdul Rahim. All rights reserved.</p>
      <p>CFP® · IFP · Licensed Financial Planner</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: clamp(4rem, 8vw, 7rem) 0 clamp(2rem, 4vw, 3rem);
    margin-top: clamp(4rem, 8vw, 6rem);
  }
  .footer__inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    padding-bottom: clamp(3rem, 6vw, 4rem);
    border-bottom: 1px solid var(--glass-border-pink);
  }
  .footer__brand {
    max-width: 440px;
  }
  .footer__logo {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--color-foreground);
    line-height: 1;
    display: inline-block;
    margin-bottom: 1.1rem;
  }
  .footer__dot {
    color: var(--color-primary);
  }
  .footer__about {
    font-size: 0.96rem;
    color: var(--color-muted-foreground);
    line-height: 1.65;
    max-width: 42ch;
    margin: 0;
  }

  .footer__cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }
  .footer__col {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .footer__col-title {
    font-size: 0.76rem;
    color: var(--color-foreground);
    font-weight: 600;
    margin-bottom: 0.5rem;
    letter-spacing: -0.005em;
  }
  .footer__col a {
    font-size: 0.95rem;
    color: var(--color-ink-2);
    transition: color 0.18s ease;
  }
  .footer__col a:hover {
    color: var(--color-primary);
  }

  .footer__bottom {
    padding-top: 1.5rem;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: 0.84rem;
    color: var(--color-muted-foreground);
  }
  .footer__bottom p {
    margin: 0;
  }

  @media (max-width: 768px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
  @media (max-width: 480px) {
    .footer__cols {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
  }
</style>
