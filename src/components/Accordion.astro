---
interface Item {
  q: string;
  a: string | string[];
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<div class="accordion">
  {
    items.map((item) => (
      <details>
        <summary>
          <span>{item.q}</span>
          <span class="accordion__chev" aria-hidden="true">
            +
          </span>
        </summary>
        <div class="accordion__answer">
          {Array.isArray(item.a) ? (
            item.a.map((p) => <p>{p}</p>)
          ) : (
            <p>{item.a}</p>
          )}
        </div>
      </details>
    ))
  }
</div>
