---
const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);

const links = [
  { href: '/', label: 'Home' },
  { href: '/planning', label: 'Financial Planning' },
  { href: '/fhc', label: 'Health Check' },
  { href: '/webinar', label: 'Webinar' },
];
---

<header class="header" id="header">
  <div class="header__inner">
    <a href="/" class="logo" aria-label="Iman Abdul Rahim · Home">
      <span class="logo__name">Iman <span class="logo__dot">.</span></span>
    </a>

    <nav aria-label="Primary" class="nav">
      <ul class="nav__links" id="navLinks">
        {
          links.map((l) => (
            <li>
              <a
                href={l.href}
                class:list={['nav__link', isActive(l.href) && 'is-active']}
              >
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <a
      href="https://form.wealthvantage.com.my/iman-lead/"
      target="_blank"
      rel="noopener"
      class="btn btn--primary btn--sm nav__cta"
    >
      Book a call
    </a>

    <button
      class="menu-toggle"
      id="menuToggle"
      type="button"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="navLinks"
    >
      <span class="menu-toggle__bar"></span>
      <span class="menu-toggle__bar"></span>
      <span class="menu-toggle__bar"></span>
    </button>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: clamp(0.75rem, 1.5vw, 1.25rem);
    left: 50%;
    transform: translateX(-50%);
    z-index: var(--z-nav);
    width: min(1180px, calc(100% - 1.5rem));
    background: rgba(255, 255, 255, 0.62);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.7);
    border-radius: 999px;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.6) inset,
      0 12px 32px -10px rgba(184, 21, 74, 0.18);
    transition: background 0.25s ease, box-shadow 0.25s ease;
  }
  .header.is-scrolled {
    background: rgba(255, 255, 255, 0.82);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.7) inset,
      0 20px 48px -12px rgba(184, 21, 74, 0.26);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 0.55rem 0.55rem 0.55rem 1.5rem;
  }

  .logo {
    display: inline-flex;
    align-items: center;
    color: var(--color-foreground);
    flex-shrink: 0;
  }
  .logo__name {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .logo__dot {
    color: var(--color-primary);
  }

  .nav__links {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0;
    margin: 0;
  }
  .nav__link {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-ink-2);
    transition: background 0.18s ease, color 0.18s ease;
    padding: 0.55rem 1rem;
    border-radius: 999px;
    letter-spacing: -0.005em;
    display: inline-block;
  }
  .nav__link:hover {
    background: rgba(255, 255, 255, 0.5);
    color: var(--color-foreground);
  }
  .nav__link.is-active {
    color: var(--color-primary);
    background: rgba(255, 214, 224, 0.5);
  }

  .nav__cta {
    flex-shrink: 0;
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: transparent;
    border: 1px solid var(--color-border-strong);
    cursor: pointer;
    padding: 0;
    color: var(--color-foreground);
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
  }
  .menu-toggle__bar {
    display: block;
    width: 18px;
    height: 1.6px;
    background: currentColor;
  }

  @media (max-width: 960px) {
    .nav__links {
      display: none;
      position: absolute;
      top: calc(100% + 0.5rem);
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      background: var(--glass-strong);
      backdrop-filter: var(--glass-blur);
      -webkit-backdrop-filter: var(--glass-blur);
      border: 1px solid var(--glass-border);
      border-radius: 24px;
      box-shadow: var(--shadow-glass-lg);
      padding: 0.6rem;
    }
    .nav__links.is-open {
      display: flex;
    }
    .nav__link {
      padding: 0.95rem 1rem;
      font-size: 1rem;
      border-radius: 14px;
      min-height: 44px;
    }
    .nav__cta {
      display: none;
    }
    .menu-toggle {
      display: inline-flex;
    }
  }
</style>
