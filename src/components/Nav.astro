---
const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="header" id="header">
  <nav class="nav container-x" aria-label="Primary">
    <a href="/" class="logo" aria-label="Iman Abdul Rahim · Home">
      <span class="logo-mark" aria-hidden="true">
        <svg viewBox="0 0 32 32" width="30" height="30" fill="none">
          <circle cx="16" cy="16" r="14.5" stroke="currentColor" stroke-width="1" opacity="0.5"></circle>
          <path d="M10.5 10v12M16 10v12M21.5 10v12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"></path>
        </svg>
      </span>
      <span class="logo-text">
        <span class="logo-name">Iman Abdul Rahim</span>
        <span class="logo-title">Licensed Financial Planner · CFP® · IFP</span>
      </span>
    </a>

    <ul class="nav-links" id="navLinks">
      <li><a href="/" class:list={['nav-link', isActive('/') && 'is-active']}>Home</a></li>
      <li><a href="/planning" class:list={['nav-link', isActive('/planning') && 'is-active']}>Financial Planning</a></li>
      <li><a href="/fhc" class:list={['nav-link', isActive('/fhc') && 'is-active']}>Health Check</a></li>
      <li><a href="/webinar" class:list={['nav-link', isActive('/webinar') && 'is-active']}>Webinar</a></li>
      <li class="nav-cta-wrap">
        <a href="https://wa.me/60186617981" target="_blank" rel="noopener" class="btn btn--rose btn--sm">Book a call</a>
      </li>
    </ul>

    <button
      class="menu-toggle"
      id="menuToggle"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="navLinks"
    >
      <span></span>
      <span></span>
    </button>
  </nav>
</header>

<style>
  .header {
    position: fixed;
    top: clamp(0.5rem, 1.4vw, 1rem);
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    width: min(1180px, calc(100% - 1.5rem));
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: saturate(170%) blur(22px);
    -webkit-backdrop-filter: saturate(170%) blur(22px);
    border: 1px solid rgba(255, 255, 255, 0.7);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.5) inset,
      0 8px 32px -8px rgba(138, 46, 74, 0.12);
    transition: background 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }
  .header.scrolled {
    background: rgba(255, 255, 255, 0.72);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.6) inset,
      0 16px 48px -10px rgba(138, 46, 74, 0.18);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 0.7rem 0.85rem 0.7rem 1.4rem;
    max-width: none;
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--color-ink);
    flex-shrink: 0;
  }
  .logo-mark {
    color: var(--color-deep);
    display: inline-flex;
    align-items: center;
  }
  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .logo-name {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 400;
    letter-spacing: -0.015em;
    color: var(--color-ink);
  }
  .logo-title {
    font-family: var(--font-sans);
    font-size: 0.64rem;
    color: var(--color-ink-3);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 500;
    margin-top: 2px;
  }

  .nav-links {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 1.6rem;
    padding: 0;
    margin: 0;
  }
  .nav-link {
    position: relative;
    font-size: 0.88rem;
    font-weight: 450;
    color: var(--color-ink-2);
    transition: color 0.2s ease;
    padding: 0.3rem 0;
  }
  .nav-link:hover { color: var(--color-deep); }
  .nav-link.is-active {
    color: var(--color-ink);
  }
  .nav-link.is-active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -3px;
    height: 1.5px;
    background: var(--color-deep);
    border-radius: 1px;
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px 10px;
    color: var(--color-ink);
  }
  .menu-toggle span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: currentColor;
    transition: transform 0.2s ease;
  }

  @media (max-width: 860px) {
    .logo-title { display: none; }
    .nav-links {
      display: none;
      position: absolute;
      top: calc(100% + 0.5rem);
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: saturate(170%) blur(22px);
      -webkit-backdrop-filter: saturate(170%) blur(22px);
      border: 1px solid rgba(255, 255, 255, 0.7);
      border-radius: 24px;
      box-shadow: 0 16px 48px -10px rgba(138, 46, 74, 0.18);
      padding: 0.75rem 1rem 1rem;
      gap: 0;
    }
    .nav-links.open { display: flex; }
    .nav-link {
      padding: 0.85rem 0.5rem;
      font-size: 0.98rem;
      border-bottom: 1px solid var(--color-hairline);
    }
    .nav-link.is-active::after { display: none; }
    .nav-cta-wrap { padding-top: 0.75rem; }
    .nav-cta-wrap .btn { width: 100%; }
    .menu-toggle { display: flex; }
  }
</style>
